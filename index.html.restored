<!DOCTYPE html>
<html lang="th" class="h-full bg-slate-50">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ระบบบริหารงานพัสดุและครุภัณฑ์โรงเรียน | School Inventory & Asset Management</title>
  
  <!-- SEO Meta Tags -->
  <meta name="description" content="ระบบสารสนเทศจัดการพัสดุสิ้นเปลือง ครุภัณฑ์ประจำปี ระบบแจ้งซ่อม และจัดซื้อจัดจ้างสำหรับสถานศึกษา">
  <meta name="theme-color" content="#4f46e5">
  
  <!-- PWA Link -->
  <link rel="manifest" href="manifest.json">
  <link rel="apple-touch-icon" href="icon-192.png">

  <!-- Google Fonts: Kanit -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Kanit', 'sans-serif'],
          },
          borderRadius: {
            '2xl': '1rem',
            '3xl': '1.5rem',
          }
        }
      }
    }
  </script>

  <!-- CDNs for icons, charts, qr codes, barcodes, excel and pdf -->
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.344.0/dist/umd/lucide.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.39.8/dist/umd/supabase.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/html5-qrcode/html5-qrcode.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/qrcode/build/qrcode.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/jspdf-autotable@3.6.0/dist/jspdf.plugin.autotable.min.js"></script>

  <style>
    body {
      font-family: 'Kanit', sans-serif;
    }
    .custom-scrollbar::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
      background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: #cbd5e1;
      border-radius: 3px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
      background: #94a3b8;
    }
    /* Smooth transitions */
    .view-transition {
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .hero-glass {
      background: rgba(255, 255, 255, 0.75);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.3);
    }
  </style>
</head>
<body class="h-full text-slate-800">

  <!-- Full-screen Spinner Loader -->
  <div id="global-loader" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/40 backdrop-blur-sm hidden">
    <div class="flex flex-col items-center p-6 bg-white shadow-2xl rounded-2xl">
      <div class="w-12 h-12 border-4 border-indigo-600 border-t-transparent rounded-full animate-spin"></div>
      <span class="mt-4 text-sm font-medium text-slate-600">กำลังประมวลผลข้อมูล...</span>
    </div>
  </div>

  <!-- Supabase Credentials Form Modal (If not configured) -->
  <div id="supabase-config-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/50 backdrop-blur-sm hidden">
    <div class="w-full max-w-md p-6 mx-4 bg-white shadow-2xl rounded-2xl">
      <div class="flex items-center space-x-3 text-indigo-600">
        <i data-lucide="database" class="w-8 h-8"></i>
        <h3 class="text-xl font-bold">เชื่อมต่อฐานข้อมูล Supabase</h3>
      </div>
      <p class="mt-2 text-sm text-slate-500">กรุณากรอกข้อมูลการเชื่อมต่อ Supabase ของท่านเพื่อเริ่มใช้งานระบบ</p>
      
      <form id="supabase-config-form" class="mt-4 space-y-4">
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">Supabase URL</label>
          <input type="url" id="config-sb-url" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="https://xxxxxx.supabase.co">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">Supabase Anon Key</label>
          <input type="text" id="config-sb-key" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...">
        </div>
        <button type="submit" class="w-full py-2.5 bg-indigo-600 text-white font-semibold rounded-xl hover:bg-indigo-700 transition duration-200">บันทึกและเชื่อมต่อ</button>
      </form>
    </div>
  </div>

  <!-- Toast Notification System -->
  <div id="toast-container" class="fixed top-5 right-5 z-50 flex flex-col space-y-2 max-w-sm w-full"></div>

  <!-- Application Container -->
  <div class="h-full flex flex-col">

    <!-- ==========================================================
         GUEST / LANDING VIEW
         ========================================================== -->
    <div id="view-landing" class="flex-1 flex flex-col bg-slate-50 overflow-y-auto">
      <!-- Navbar -->
      <nav class="sticky top-0 z-30 bg-white/80 backdrop-blur-md border-b border-slate-100 px-6 py-4 flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <div class="p-2 bg-indigo-600 text-white rounded-xl">
            <i data-lucide="shield" class="w-6 h-6"></i>
          </div>
          <div>
            <h1 class="text-lg font-bold text-slate-900 leading-tight">ระบบพัสดุและครุภัณฑ์โรงเรียน</h1>
            <p class="text-xs text-slate-500">School Inventory & Asset System</p>
          </div>
        </div>
        <div class="flex items-center space-x-3">
          <button onclick="toggleConfigModal()" class="p-2 text-slate-500 hover:text-indigo-600 hover:bg-slate-100 rounded-xl transition">
            <i data-lucide="settings" class="w-5 h-5"></i>
          </button>
          <button onclick="showLoginModal()" class="px-5 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-xl hover:bg-indigo-700 shadow-md shadow-indigo-100 hover:shadow-lg transition">
            เข้าสู่ระบบ
          </button>
        </div>
      </nav>

      <!-- Hero Section (Glassmorphism) -->
      <div class="relative py-12 px-6 sm:px-12 max-w-7xl mx-auto w-full flex-1 flex flex-col justify-center">
        <div class="absolute inset-0 -z-10 flex items-center justify-center opacity-30 pointer-events-none">
          <div class="w-[500px] h-[500px] bg-indigo-300 rounded-full blur-[120px]"></div>
          <div class="w-[400px] h-[400px] bg-emerald-200 rounded-full blur-[100px] ml-40"></div>
        </div>

        <div class="hero-glass rounded-3xl p-8 sm:p-12 shadow-xl border border-white/50 text-center max-w-4xl mx-auto">
          <span class="px-4 py-1.5 bg-indigo-50 text-indigo-700 text-xs font-bold rounded-full border border-indigo-100">เวอร์ชันระบบจัดซื้อ-เบิกจ่ายครบวงจร</span>
          <h2 class="mt-6 text-3xl sm:text-5xl font-extrabold text-slate-900 tracking-tight leading-tight">
            ระบบสารสนเทศงานพัสดุและครุภัณฑ์ <br class="hidden sm:inline">
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-indigo-800">ยุคใหม่สำหรับสถานศึกษา</span>
          </h2>
          <p class="mt-4 text-base sm:text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed">
            บริหารจัดการพัสดุสิ้นเปลือง ครุภัณฑ์ประจำปี การแจ้งซ่อมบำรุง และระบบจัดซื้อจัดจ้างผ่านแพลตฟอร์มเดียว รองรับการใช้งานบนมือถือ ตรวจสอบครุภัณฑ์ผ่าน QR Code แบบเรียลไทม์
          </p>

          <!-- Landing Overview Stats Grid -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-10 text-left">
            <div class="bg-white/80 p-5 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
              <div class="p-3 bg-indigo-50 text-indigo-600 rounded-xl">
                <i data-lucide="box" class="w-6 h-6"></i>
              </div>
              <div>
                <p class="text-xs text-slate-500 font-medium">รายการพัสดุ</p>
                <h4 id="landing-count-inventory" class="text-xl font-bold text-slate-800">...</h4>
              </div>
            </div>
            <div class="bg-white/80 p-5 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
              <div class="p-3 bg-emerald-50 text-emerald-600 rounded-xl">
                <i data-lucide="cpu" class="w-6 h-6"></i>
              </div>
              <div>
                <p class="text-xs text-slate-500 font-medium">ครุภัณฑ์ทั้งหมด</p>
                <h4 id="landing-count-assets" class="text-xl font-bold text-slate-800">...</h4>
              </div>
            </div>
            <div class="bg-white/80 p-5 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
              <div class="p-3 bg-amber-50 text-amber-600 rounded-xl">
                <i data-lucide="alert-triangle" class="w-6 h-6"></i>
              </div>
              <div>
                <p class="text-xs text-slate-500 font-medium">ครุภัณฑ์ชำรุด</p>
                <h4 id="landing-count-damaged" class="text-xl font-bold text-slate-800">...</h4>
              </div>
            </div>
            <div class="bg-white/80 p-5 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
              <div class="p-3 bg-indigo-50 text-indigo-600 rounded-xl">
                <i data-lucide="banknote" class="w-6 h-6"></i>
              </div>
              <div>
                <p class="text-xs text-slate-500 font-medium">มูลค่าสินทรัพย์รวม</p>
                <h4 id="landing-total-value" class="text-xl font-bold text-slate-800">...</h4>
              </div>
            </div>
          </div>

          <div class="mt-8 flex flex-col sm:flex-row justify-center items-center gap-4">
            <button onclick="showLoginModal()" class="w-full sm:w-auto px-8 py-3 bg-indigo-600 text-white font-semibold rounded-xl hover:bg-indigo-700 shadow-md shadow-indigo-100 hover:shadow-lg transition">
              เริ่มต้นใช้งานระบบ
            </button>
            <a href="#landing-features" class="w-full sm:w-auto px-8 py-3 bg-white text-slate-700 font-semibold rounded-xl border border-slate-200 hover:bg-slate-50 transition">
              ดูรายละเอียดฟีเจอร์
            </a>
          </div>
        </div>
      </div>

      <!-- Features Details Section -->
      <div id="landing-features" class="bg-white border-t border-slate-100 py-16 px-6">
        <div class="max-w-7xl mx-auto">
          <div class="text-center max-w-3xl mx-auto">
            <h3 class="text-2xl sm:text-3xl font-bold text-slate-900">ฟังก์ชันครอบคลุมทุกงานบริหารพัสดุโรงเรียน</h3>
            <p class="mt-3 text-slate-500">รวดเร็ว แม่นยำ และทำงานร่วมกันได้แบบไร้รอยต่อทั้งผู้บริหาร ครู และเจ้าหน้าที่พัสดุ</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
            <div class="p-6 bg-slate-50 rounded-2xl border border-slate-100 hover:shadow-md transition">
              <div class="w-12 h-12 bg-indigo-500 text-white flex items-center justify-center rounded-xl">
                <i data-lucide="box" class="w-6 h-6"></i>
              </div>
              <h4 class="text-lg font-bold text-slate-900 mt-4">1. จัดการพัสดุ (วัสดุสิ้นเปลือง)</h4>
              <p class="text-sm text-slate-500 mt-2 leading-relaxed">เบิก-จ่ายสต็อก ตัดสต็อกและเตือนวัสดุใกล้หมดแบบเรียลไทม์ พร้อมบันทึกประวัติการรับเข้าและคืนวัสดุอัตโนมัติ</p>
            </div>

            <div class="p-6 bg-slate-50 rounded-2xl border border-slate-100 hover:shadow-md transition">
              <div class="w-12 h-12 bg-emerald-500 text-white flex items-center justify-center rounded-xl">
                <i data-lucide="cpu" class="w-6 h-6"></i>
              </div>
              <h4 class="text-lg font-bold text-slate-900 mt-4">2. ทะเบียนและตรวจสอบครุภัณฑ์</h4>
              <p class="text-sm text-slate-500 mt-2 leading-relaxed">ค้นหาและพิมพ์สติ๊กเกอร์ QR Code / Barcode รองรับการตรวจสอบครุภัณฑ์ผ่านมือถือเพียงแค่เดินสแกนแล้วเลือกสถานะ</p>
            </div>

            <div class="p-6 bg-slate-50 rounded-2xl border border-slate-100 hover:shadow-md transition">
              <div class="w-12 h-12 bg-amber-500 text-white flex items-center justify-center rounded-xl">
                <i data-lucide="wrench" class="w-6 h-6"></i>
              </div>
              <h4 class="text-lg font-bold text-slate-900 mt-4">3. แจ้งซ่อมบำรุงและจัดซื้อจัดจ้าง</h4>
              <p class="text-sm text-slate-500 mt-2 leading-relaxed">ครูผู้สอนสามารถสแกนแจ้งซ่อมครุภัณฑ์พร้อมถ่ายภาพแนบได้ทันที ระบบจัดซื้ออัปเดตยอดสต็อกอัตโนมัติเมื่อตรวจรับ</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Login Modal overlay -->
    <div id="login-modal" class="fixed inset-0 z-40 flex items-center justify-center bg-slate-900/50 backdrop-blur-sm hidden">
      <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md p-8 mx-4 relative transform transition-all duration-300 scale-95 opacity-0" id="login-modal-content">
        <button onclick="hideLoginModal()" class="absolute top-4 right-4 p-2 text-slate-400 hover:text-slate-600 rounded-full hover:bg-slate-100 transition">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
        <div class="text-center">
          <div class="w-16 h-16 bg-indigo-50 text-indigo-600 flex items-center justify-center rounded-2xl mx-auto">
            <i data-lucide="lock" class="w-8 h-8"></i>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mt-4">เข้าสู่ระบบ</h3>
          <p class="text-sm text-slate-500 mt-1">กรอกข้อมูลผู้ใช้งานของคุณเพื่อจัดการพัสดุโรงเรียน</p>
        </div>

        <form id="login-form" class="mt-6 space-y-4">
          <div>
            <label class="block text-sm font-semibold text-slate-700">ชื่อผู้ใช้งาน</label>
            <input type="text" id="login-username" required class="w-full px-4 py-2.5 mt-1 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="ระบุ username">
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-700">รหัสผ่าน</label>
            <input type="password" id="login-password" required class="w-full px-4 py-2.5 mt-1 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="ระบุ password">
          </div>
          <div class="text-xs text-slate-400 leading-relaxed bg-slate-50 p-3 rounded-lg">
            <strong>ข้อมูลผู้ใช้เริ่มต้นสำหรับการทดสอบ:</strong><br>
            • ผู้ดูแลระบบ: admin / admin123<br>
            • เจ้าหน้าที่พัสดุ: officer / officer123<br>
            • ครูผู้สอน: teacher / teacher123<br>
            • ผู้บริหาร: exec / exec123
          </div>
          <button type="submit" class="w-full py-3 bg-indigo-600 text-white font-semibold rounded-xl hover:bg-indigo-700 shadow-md shadow-indigo-100 hover:shadow-lg transition">เข้าสู่ระบบ</button>
        </form>
      </div>
    </div>


    <!-- ==========================================================
         AUTHENTICATED MAIN LAYOUT
         ========================================================== -->
    <div id="view-app" class="flex-1 flex flex-col md:flex-row overflow-hidden hidden">

      <!-- LEFT SIDEBAR - Desktop View -->
      <aside class="hidden md:flex flex-col w-64 bg-slate-900 text-slate-200 flex-shrink-0 border-r border-slate-800">
        <!-- Logo Header -->
        <div class="px-6 py-5 border-b border-slate-800 flex items-center space-x-3 bg-slate-950">
          <div class="p-1.5 bg-indigo-600 text-white rounded-lg">
            <i data-lucide="shield" class="w-5 h-5"></i>
          </div>
          <div>
            <h1 class="text-sm font-bold text-white leading-none">งานพัสดุโรงเรียน</h1>
            <span class="text-[10px] text-indigo-400">Inventory & Asset App</span>
          </div>
        </div>

        <!-- User profile panel -->
        <div class="p-4 border-b border-slate-800 flex items-center space-x-3 bg-slate-900/50">
          <div class="w-10 h-10 rounded-full bg-slate-700 flex items-center justify-center text-white font-bold text-lg" id="desktop-avatar">
            U
          </div>
          <div class="overflow-hidden">
            <h4 id="desktop-user-name" class="text-sm font-semibold text-white truncate">ชื่อผู้ใช้งาน</h4>
            <p id="desktop-user-role" class="text-xs text-slate-400 truncate">บทบาท</p>
          </div>
        </div>

        <!-- Sidebar Navigation Menu -->
        <nav class="flex-1 px-4 py-4 space-y-1 overflow-y-auto custom-scrollbar" id="desktop-nav">
          <!-- Dynamically populated via JS depending on user role -->
        </nav>

        <!-- Logout button -->
        <div class="p-4 border-t border-slate-800">
          <button onclick="confirmLogout()" class="w-full flex items-center space-x-3 px-4 py-2.5 text-slate-400 hover:text-white hover:bg-slate-800 rounded-xl transition">
            <i data-lucide="log-out" class="w-5 h-5"></i>
            <span class="text-sm font-semibold">ออกจากระบบ</span>
          </button>
        </div>
      </aside>

      <!-- CONTENT CONTAINER -->
      <main class="flex-1 flex flex-col overflow-hidden">
        
        <!-- Header - Mobile & Desktop -->
        <header class="h-16 bg-white border-b border-slate-100 px-6 flex items-center justify-between z-10">
          <div class="flex items-center space-x-3 md:hidden">
            <!-- Mobile Logo -->
            <div class="p-1.5 bg-indigo-600 text-white rounded-lg">
              <i data-lucide="shield" class="w-4 h-4"></i>
            </div>
            <h2 class="text-sm font-bold text-slate-900 leading-none">งานพัสดุ</h2>
          </div>
          
          <div class="hidden md:flex items-center space-x-2 text-slate-500 text-sm">
            <i data-lucide="home" class="w-4 h-4"></i>
            <span>/</span>
            <span id="breadcrumb-current" class="font-medium text-slate-800">แดชบอร์ด</span>
          </div>

          <!-- Right side tools -->
          <div class="flex items-center space-x-3">
            <!-- Low stock alert indicator -->
            <div id="low-stock-alert-btn" class="relative p-2 text-slate-500 hover:text-amber-600 hover:bg-slate-50 rounded-xl cursor-pointer transition hidden" onclick="switchView('view-reports')">
              <i data-lucide="bell" class="w-5 h-5"></i>
              <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-amber-500 rounded-full"></span>
            </div>
            <!-- Custom Database Status/Re-configure -->
            <button onclick="toggleConfigModal()" class="p-2 text-slate-500 hover:text-indigo-600 hover:bg-slate-50 rounded-xl transition" title="ตั้งค่าการเชื่อมต่อ">
              <i data-lucide="settings" class="w-5 h-5"></i>
            </button>
            <div class="h-8 w-px bg-slate-100"></div>
            <span id="app-user-role-badge" class="px-2.5 py-1 bg-indigo-50 text-indigo-700 text-xs font-bold rounded-full border border-indigo-100">ผู้ดูแลระบบ</span>
          </div>
        </header>

        <!-- MAIN SCROLLABLE CONTENT -->
        <div class="flex-1 overflow-y-auto custom-scrollbar p-6 bg-slate-50" id="main-content-scroll">
          
          <!-- VIEW 1: EXECUTIVE DASHBOARD -->
          <section id="subview-dashboard" class="space-y-6 view-transition hidden">
            <!-- Top stats -->
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
              <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
                <div class="p-3.5 bg-indigo-50 text-indigo-600 rounded-xl">
                  <i data-lucide="box" class="w-6 h-6"></i>
                </div>
                <div>
                  <p class="text-xs text-slate-500 font-medium">พัสดุทั้งหมด</p>
                  <h3 id="stat-total-inventory" class="text-2xl font-bold text-slate-800">...</h3>
                </div>
              </div>
              <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
                <div class="p-3.5 bg-sky-50 text-sky-600 rounded-xl">
                  <i data-lucide="cpu" class="w-6 h-6"></i>
                </div>
                <div>
                  <p class="text-xs text-slate-500 font-medium">ครุภัณฑ์ทั้งหมด</p>
                  <h3 id="stat-total-assets" class="text-2xl font-bold text-slate-800">...</h3>
                </div>
              </div>
              <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
                <div class="p-3.5 bg-amber-50 text-amber-600 rounded-xl">
                  <i data-lucide="alert-triangle" class="w-6 h-6"></i>
                </div>
                <div>
                  <p class="text-xs text-slate-500 font-medium">รายการใกล้หมด</p>
                  <h3 id="stat-low-stock" class="text-2xl font-bold text-slate-800 text-amber-600">...</h3>
                </div>
              </div>
              <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
                <div class="p-3.5 bg-emerald-50 text-emerald-600 rounded-xl">
                  <i data-lucide="banknote" class="w-6 h-6"></i>
                </div>
                <div>
                  <p class="text-xs text-slate-500 font-medium">มูลค่าทรัพย์สินรวม</p>
                  <h3 id="stat-total-asset-value" class="text-2xl font-bold text-slate-800">...</h3>
                </div>
              </div>
            </div>

            <!-- Second row stats -->
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
              <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
                <div class="p-3.5 bg-rose-50 text-rose-600 rounded-xl">
                  <i data-lucide="wrench" class="w-6 h-6"></i>
                </div>
                <div>
                  <p class="text-xs text-slate-500 font-medium">ครุภัณฑ์ชำรุด</p>
                  <h3 id="stat-damaged-assets" class="text-2xl font-bold text-slate-800 text-rose-600">...</h3>
                </div>
              </div>
              <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
                <div class="p-3.5 bg-indigo-50 text-indigo-600 rounded-xl">
                  <i data-lucide="clock" class="w-6 h-6"></i>
                </div>
                <div>
                  <p class="text-xs text-slate-500 font-medium">รอการอนุมัติเบิก</p>
                  <h3 id="stat-pending-requests" class="text-2xl font-bold text-slate-800">...</h3>
                </div>
              </div>
              <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
                <div class="p-3.5 bg-teal-50 text-teal-600 rounded-xl">
                  <i data-lucide="clipboard-check" class="w-6 h-6"></i>
                </div>
                <div>
                  <p class="text-xs text-slate-500 font-medium">รอตรวจสอบปีนี้</p>
                  <h3 id="stat-pending-inspection" class="text-2xl font-bold text-slate-800">...</h3>
                </div>
              </div>
              <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
                <div class="p-3.5 bg-emerald-50 text-emerald-600 rounded-xl">
                  <i data-lucide="star" class="w-6 h-6"></i>
                </div>
                <div>
                  <p class="text-xs text-slate-500 font-medium">เบิกบ่อยที่สุด</p>
                  <h3 id="stat-most-requested" class="text-lg font-bold text-slate-800 truncate" style="max-width: 140px;">-</h3>
                </div>
              </div>
            </div>

            <!-- Charts and AI predictions -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
              <!-- Graph -->
              <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 lg:col-span-2">
                <div class="flex items-center justify-between mb-4">
                  <h4 class="font-bold text-slate-900 flex items-center gap-2">
                    <i data-lucide="bar-chart-2" class="w-5 h-5 text-indigo-600"></i>
                    สถิติการเบิก-จ่ายพัสดุรายเดือน
                  </h4>
                </div>
                <div class="h-64 relative">
                  <canvas id="monthly-stats-chart"></canvas>
                </div>
              </div>

              <!-- AI Trend Analysis -->
              <div class="bg-gradient-to-br from-indigo-900 to-slate-900 text-white p-6 rounded-2xl shadow-lg border border-slate-800 flex flex-col justify-between">
                <div>
                  <div class="flex items-center justify-between">
                    <span class="px-3 py-1 bg-indigo-500/20 text-indigo-300 text-xs font-bold rounded-full border border-indigo-400/20 flex items-center gap-1.5">
                      <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
                      AI Analytics
                    </span>
                    <i data-lucide="sparkles" class="w-6 h-6 text-yellow-400"></i>
                  </div>
                  <h4 class="text-lg font-bold mt-4 leading-snug">วิเคราะห์แนวโน้มการใช้พัสดุโรงเรียน</h4>
                  <p class="text-xs text-indigo-200 mt-1">คำนวณและคาดการณ์ปริมาณความต้องการวัสดุสิ้นเปลืองรายถัดไป</p>

                  <div class="mt-6 space-y-3" id="ai-predictions-container">
                    <!-- Loaded dynamically via JS -->
                    <div class="animate-pulse flex space-x-3">
                      <div class="flex-1 space-y-2 py-1">
                        <div class="h-3 bg-slate-700 rounded w-3/4"></div>
                        <div class="h-3 bg-slate-700 rounded"></div>
                        <div class="h-3 bg-slate-700 rounded w-5/6"></div>
                      </div>
                    </div>
                  </div>
                </div>
                <button onclick="switchView('view-reports')" class="mt-6 w-full py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-semibold rounded-xl transition flex items-center justify-center gap-1.5">
                  <i data-lucide="eye" class="w-3.5 h-3.5"></i>
                  ดูรายงานเชิงลึก
                </button>
              </div>
            </div>

            <!-- Pending Request list (For approvals) -->
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
              <div class="flex items-center justify-between mb-4">
                <h4 class="font-bold text-slate-900 flex items-center gap-2">
                  <i data-lucide="clipboard-list" class="w-5 h-5 text-indigo-600"></i>
                  รายการเบิกพัสดุรออนุมัติ
                </h4>
                <button onclick="switchView('view-inventory')" class="text-xs font-semibold text-indigo-600 hover:underline">ดูพัสดุทั้งหมด</button>
              </div>
              <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                  <thead>
                    <tr class="border-b border-slate-100 text-slate-400 text-xs font-semibold">
                      <th class="py-3 px-4">วันที่</th>
                      <th class="py-3 px-4">ผู้เบิก</th>
                      <th class="py-3 px-4">กลุ่มสาระฯ</th>
                      <th class="py-3 px-4">รายการพัสดุ</th>
                      <th class="py-3 px-4">จำนวนเบิก</th>
                      <th class="py-3 px-4 text-center">การจัดการ</th>
                    </tr>
                  </thead>
                  <tbody id="dashboard-requests-list" class="text-sm divide-y divide-slate-100 text-slate-600">
                    <tr>
                      <td colspan="6" class="py-8 text-center text-slate-400">ไม่มีรายการค้างอนุมัติ</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </section>

          <!-- VIEW 2: INVENTORY MANAGEMENT -->
          <section id="subview-inventory" class="space-y-6 view-transition hidden">
            <!-- Action buttons & search -->
            <div class="flex flex-col sm:flex-row justify-between items-stretch sm:items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-slate-100">
              <div class="relative flex-1">
                <i data-lucide="search" class="w-5 h-5 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
                <input type="text" id="inventory-search" placeholder="ค้นหาชื่อพัสดุ, รหัส, หรือประเภท..." class="w-full pl-10 pr-4 py-2 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm">
              </div>
              <div class="flex flex-wrap gap-2">
                <button onclick="openReceiveStockModal()" class="px-4 py-2 bg-indigo-600 text-white text-xs font-semibold rounded-xl hover:bg-indigo-700 flex items-center gap-1.5 transition shadow-sm officer-admin-only">
                  <i data-lucide="plus" class="w-4 h-4"></i>
                  รับพัสดุเข้าคลัง
                </button>
                <button onclick="openRequestBorrowModal()" class="px-4 py-2 bg-emerald-600 text-white text-xs font-semibold rounded-xl hover:bg-emerald-700 flex items-center gap-1.5 transition shadow-sm">
                  <i data-lucide="shopping-bag" class="w-4 h-4"></i>
                  ขอเบิกพัสดุ
                </button>
                <button onclick="openReturnStockModal()" class="px-4 py-2 bg-slate-600 text-white text-xs font-semibold rounded-xl hover:bg-slate-700 flex items-center gap-1.5 transition shadow-sm">
                  <i data-lucide="refresh-cw" class="w-4 h-4"></i>
                  คืนพัสดุ (กรณีเบิกเกิน)
                </button>
              </div>
            </div>

            <!-- Inventory Table Card -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
              <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                  <thead>
                    <tr class="bg-slate-50 border-b border-slate-100 text-slate-500 text-xs font-semibold">
                      <th class="py-3 px-4">รหัสพัสดุ</th>
                      <th class="py-3 px-4">ชื่อพัสดุ</th>
                      <th class="py-3 px-4">ประเภท</th>
                      <th class="py-3 px-4">คงเหลือ/หน่วย</th>
                      <th class="py-3 px-4">รับเข้า/เบิกออก</th>
                      <th class="py-3 px-4">ราคาต่อหน่วย</th>
                      <th class="py-3 px-4">สถานที่จัดเก็บ</th>
                      <th class="py-3 px-4 text-center">การจัดการ</th>
                    </tr>
                  </thead>
                  <tbody id="inventory-list" class="text-sm divide-y divide-slate-100 text-slate-600">
                    <!-- Dynamically populated -->
                  </tbody>
                </table>
              </div>
            </div>
          </section>

          <!-- VIEW 3: ASSET MANAGEMENT -->
          <section id="subview-assets" class="space-y-6 view-transition hidden">
            <!-- Filters, search and actions -->
            <div class="flex flex-col sm:flex-row justify-between items-stretch sm:items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-slate-100">
              <div class="relative flex-1">
                <i data-lucide="search" class="w-5 h-5 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
                <input type="text" id="asset-search" placeholder="ค้นหาชื่อครุภัณฑ์, เลขครุภัณฑ์, สถานที่ติดตั้ง..." class="w-full pl-10 pr-4 py-2 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm">
              </div>
              <div class="flex gap-2">
                <button onclick="openScanQrModal('view_asset')" class="px-4 py-2 bg-slate-800 text-white text-xs font-semibold rounded-xl hover:bg-slate-900 flex items-center gap-1.5 transition shadow-sm">
                  <i data-lucide="qr-code" class="w-4 h-4"></i>
                  สแกนดูครุภัณฑ์
                </button>
                <button onclick="openAddAssetModal()" class="px-4 py-2 bg-indigo-600 text-white text-xs font-semibold rounded-xl hover:bg-indigo-700 flex items-center gap-1.5 transition shadow-sm officer-admin-only">
                  <i data-lucide="plus" class="w-4 h-4"></i>
                  เพิ่มครุภัณฑ์ใหม่
                </button>
              </div>
            </div>

            <!-- Asset Table Card -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
              <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                  <thead>
                    <tr class="bg-slate-50 border-b border-slate-100 text-slate-500 text-xs font-semibold">
                      <th class="py-3 px-4">รูปภาพ</th>
                      <th class="py-3 px-4">เลขครุภัณฑ์</th>
                      <th class="py-3 px-4">ชื่อครุภัณฑ์</th>
                      <th class="py-3 px-4">ยี่ห้อ/รุ่น</th>
                      <th class="py-3 px-4">ห้อง/สถานที่ติดตั้ง</th>
                      <th class="py-3 px-4">ผู้รับผิดชอบ</th>
                      <th class="py-3 px-4">สถานะ</th>
                      <th class="py-3 px-4 text-center">การจัดการ</th>
                    </tr>
                  </thead>
                  <tbody id="assets-list" class="text-sm divide-y divide-slate-100 text-slate-600">
                    <!-- Dynamically populated -->
                  </tbody>
                </table>
              </div>
            </div>
          </section>

          <!-- VIEW 4: ANNUAL ASSET CHECK -->
          <section id="subview-asset-checks" class="space-y-6 view-transition hidden">
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
              <div class="text-center max-w-md mx-auto">
                <div class="w-16 h-16 bg-indigo-50 text-indigo-600 flex items-center justify-center rounded-2xl mx-auto">
                  <i data-lucide="clipboard-check" class="w-8 h-8"></i>
                </div>
                <h3 class="text-xl font-bold mt-4">ตรวจสอบครุภัณฑ์ประจำปี</h3>
                <p class="text-sm text-slate-500 mt-2">สแกนรหัส QR Code บนครุภัณฑ์เพื่อบันทึกประวัติการตรวจสอบสถานะประจำปีอย่างรวดเร็ว</p>
                <div class="mt-6 flex flex-col gap-2">
                  <button onclick="openScanQrModal('annual_check')" class="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl flex items-center justify-center gap-2 transition shadow-md shadow-indigo-100">
                    <i data-lucide="scan-line" class="w-5 h-5"></i>
                    สแกน QR Code เพื่อเดินตรวจ
                  </button>
                  <button onclick="switchView('view-reports')" class="w-full py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 text-xs font-semibold rounded-xl transition">
                    ดูรายงานผลการตรวจสอบประจำปี
                  </button>
                </div>
              </div>
            </div>

            <!-- Recent inspection history -->
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
              <h4 class="font-bold text-slate-900 mb-4 flex items-center gap-2">
                <i data-lucide="history" class="w-5 h-5 text-indigo-600"></i>
                ประวัติการตรวจล่าสุด
              </h4>
              <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                  <thead>
                    <tr class="border-b border-slate-100 text-slate-400 text-xs font-semibold">
                      <th class="py-3 px-4">วันเวลา</th>
                      <th class="py-3 px-4">เลขครุภัณฑ์</th>
                      <th class="py-3 px-4">ชื่อครุภัณฑ์</th>
                      <th class="py-3 px-4">ผู้ตรวจสอบ</th>
                      <th class="py-3 px-4">สถานะที่บันทึก</th>
                      <th class="py-3 px-4">หมายเหตุ</th>
                    </tr>
                  </thead>
                  <tbody id="asset-checks-history-list" class="text-sm divide-y divide-slate-100 text-slate-600">
                    <tr>
                      <td colspan="6" class="py-8 text-center text-slate-400">ยังไม่มีข้อมูลการเดินตรวจในระบบ</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </section>

          <!-- VIEW 5: REPAIR REQUEST SYSTEM -->
          <section id="subview-asset-repairs" class="space-y-6 view-transition hidden">
            <!-- Headline and action -->
            <div class="flex justify-between items-center bg-white p-4 rounded-2xl shadow-sm border border-slate-100">
              <h3 class="font-bold text-slate-800 flex items-center gap-2">
                <i data-lucide="wrench" class="w-5 h-5 text-indigo-600"></i>
                การแจ้งซ่อมครุภัณฑ์
              </h3>
              <button onclick="openScanQrModal('report_repair')" class="px-4 py-2 bg-rose-600 hover:bg-rose-700 text-white text-xs font-semibold rounded-xl flex items-center gap-1.5 transition shadow-sm">
                <i data-lucide="alert-circle" class="w-4 h-4"></i>
                แจ้งซ่อมด่วน (สแกน QR)
              </button>
            </div>

            <!-- Repairs grid/list -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
              <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                  <thead>
                    <tr class="bg-slate-50 border-b border-slate-100 text-slate-500 text-xs font-semibold">
                      <th class="py-3 px-4">รูปแนบ</th>
                      <th class="py-3 px-4">วันที่แจ้ง</th>
                      <th class="py-3 px-4">ครุภัณฑ์</th>
                      <th class="py-3 px-4">อาการเสีย</th>
                      <th class="py-3 px-4">ผู้แจ้ง/กลุ่มสาระ</th>
                      <th class="py-3 px-4">สถานะ</th>
                      <th class="py-3 px-4 text-center">จัดการสถานะ (เจ้าหน้าที่/แอดมิน)</th>
                    </tr>
                  </thead>
                  <tbody id="asset-repairs-list" class="text-sm divide-y divide-slate-100 text-slate-600">
                    <!-- Dynamically populated -->
                  </tbody>
                </table>
              </div>
            </div>
          </section>

          <!-- VIEW 6: PROCUREMENT SYSTEM -->
          <section id="subview-procurements" class="space-y-6 view-transition hidden">
            <!-- procurement list header -->
            <div class="flex justify-between items-center bg-white p-4 rounded-2xl shadow-sm border border-slate-100">
              <h3 class="font-bold text-slate-800 flex items-center gap-2">
                <i data-lucide="file-text" class="w-5 h-5 text-indigo-600"></i>
                ระบบจัดซื้อจัดจ้าง
              </h3>
              <button onclick="openAddProcurementModal()" class="px-4 py-2 bg-indigo-600 text-white text-xs font-semibold rounded-xl hover:bg-indigo-700 flex items-center gap-1.5 transition shadow-sm officer-admin-only">
                <i data-lucide="plus" class="w-4 h-4"></i>
                สร้างโครงการจัดซื้อใหม่
              </button>
            </div>

            <!-- Procurement table -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
              <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                  <thead>
                    <tr class="bg-slate-50 border-b border-slate-100 text-slate-500 text-xs font-semibold">
                      <th class="py-3 px-4">ชื่อโครงการ</th>
                      <th class="py-3 px-4">ปีงบประมาณ</th>
                      <th class="py-3 px-4">ผู้ขาย/บริษัทคู่สัญญา</th>
                      <th class="py-3 px-4">เอกสารแนบ (ใบเสนอราคา, PO, ตรวจรับ)</th>
                      <th class="py-3 px-4">รายการสินค้าจัดซื้อ</th>
                      <th class="py-3 px-4">สถานะโครงการ</th>
                      <th class="py-3 px-4 text-center">การอนุมัติ</th>
                    </tr>
                  </thead>
                  <tbody id="procurements-list" class="text-sm divide-y divide-slate-100 text-slate-600">
                    <!-- Dynamically populated -->
                  </tbody>
                </table>
              </div>
            </div>
          </section>

          <!-- VIEW 7: REPORTS SYSTEM -->
          <section id="subview-reports" class="space-y-6 view-transition hidden">
            <!-- Report cards selection grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              <!-- Report 1: Low Stock Report -->
              <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm flex flex-col justify-between">
                <div>
                  <div class="flex items-center space-x-3 text-amber-500">
                    <i data-lucide="alert-triangle" class="w-6 h-6"></i>
                    <h4 class="font-bold text-slate-900">พัสดุใกล้หมดคลัง</h4>
                  </div>
                  <p class="text-xs text-slate-500 mt-2">แสดงวัสดุสิ้นเปลืองที่มีสต็อกต่ำกว่าจุดวิกฤต (Minimum Threshold)</p>
                </div>
                <div class="mt-4 flex gap-2">
                  <button onclick="viewReportDetail('low_stock')" class="px-4 py-2 bg-indigo-50 text-indigo-700 text-xs font-semibold rounded-xl border border-indigo-100 hover:bg-indigo-100 transition flex-1">เรียกดูรายงาน</button>
                  <button onclick="exportReport('low_stock', 'excel')" class="p-2 bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-xl transition text-slate-600" title="ส่งออก Excel">
                    <i data-lucide="file-spreadsheet" class="w-4 h-4"></i>
                  </button>
                </div>
              </div>

              <!-- Report 2: Borrowing Logs -->
              <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm flex flex-col justify-between">
                <div>
                  <div class="flex items-center space-x-3 text-indigo-500">
                    <i data-lucide="shopping-bag" class="w-6 h-6"></i>
                    <h4 class="font-bold text-slate-900">รายงานเบิกจ่ายพัสดุ</h4>
                  </div>
                  <p class="text-xs text-slate-500 mt-2">ประวัติการขอเบิกพัสดุโดยครูและกลุ่มสาระฯ รายวัน รายเดือน รายปี</p>
                </div>
                <div class="mt-4 flex gap-2">
                  <button onclick="viewReportDetail('borrow_logs')" class="px-4 py-2 bg-indigo-50 text-indigo-700 text-xs font-semibold rounded-xl border border-indigo-100 hover:bg-indigo-100 transition flex-1">เรียกดูรายงาน</button>
                  <button onclick="exportReport('borrow_logs', 'excel')" class="p-2 bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-xl transition text-slate-600" title="ส่งออก Excel">
                    <i data-lucide="file-spreadsheet" class="w-4 h-4"></i>
                  </button>
                </div>
              </div>

              <!-- Report 3: Asset Status Report -->
              <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm flex flex-col justify-between">
                <div>
                  <div class="flex items-center space-x-3 text-emerald-500">
                    <i data-lucide="cpu" class="w-6 h-6"></i>
                    <h4 class="font-bold text-slate-900">รายงานครุภัณฑ์ตามหมวด</h4>
                  </div>
                  <p class="text-xs text-slate-500 mt-2">แสดงรายการทรัพย์สินตามอาคาร ห้องผู้รับผิดชอบ และปีงบประมาณ</p>
                </div>
                <div class="mt-4 flex gap-2">
                  <button onclick="viewReportDetail('assets_group')" class="px-4 py-2 bg-indigo-50 text-indigo-700 text-xs font-semibold rounded-xl border border-indigo-100 hover:bg-indigo-100 transition flex-1">เรียกดูรายงาน</button>
                  <button onclick="exportReport('assets_group', 'excel')" class="p-2 bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-xl transition text-slate-600" title="ส่งออก Excel">
                    <i data-lucide="file-spreadsheet" class="w-4 h-4"></i>
                  </button>
                </div>
              </div>
            </div>

            <!-- Report Details display panel -->
            <div id="report-details-panel" class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm hidden">
              <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
                <div>
                  <h4 id="report-title" class="text-lg font-bold text-slate-800">รายละเอียดรายงาน</h4>
                  <p id="report-desc" class="text-xs text-slate-500">คำอธิบายรายงาน</p>
                </div>
                <div class="flex gap-2 w-full sm:w-auto">
                  <button id="btn-export-pdf" class="px-4 py-2 bg-indigo-600 text-white text-xs font-semibold rounded-xl hover:bg-indigo-700 flex items-center justify-center gap-1.5 transition flex-1 sm:flex-initial">
                    <i data-lucide="file-text" class="w-4 h-4"></i>
                    ดาวน์โหลด PDF
                  </button>
                  <button id="btn-export-excel" class="px-4 py-2 bg-emerald-600 text-white text-xs font-semibold rounded-xl hover:bg-emerald-700 flex items-center justify-center gap-1.5 transition flex-1 sm:flex-initial">
                    <i data-lucide="file-spreadsheet" class="w-4 h-4"></i>
                    ส่งออก Excel
                  </button>
                </div>
              </div>
              <div class="overflow-x-auto custom-scrollbar">
                <table class="w-full text-left border-collapse" id="report-result-table">
                  <thead id="report-result-header" class="bg-slate-50 border-b border-slate-100 text-slate-500 text-xs font-semibold">
                    <!-- Dynamic -->
                  </thead>
                  <tbody id="report-result-body" class="text-sm divide-y divide-slate-100 text-slate-600">
                    <!-- Dynamic -->
                  </tbody>
                </table>
              </div>
            </div>
          </section>

          <!-- VIEW 8: USER MANAGEMENT (ADMIN ONLY) -->
          <section id="subview-user-management" class="space-y-6 view-transition hidden">
            <!-- actions -->
            <div class="flex justify-between items-center bg-white p-4 rounded-2xl shadow-sm border border-slate-100">
              <h3 class="font-bold text-slate-800 flex items-center gap-2">
                <i data-lucide="users" class="w-5 h-5 text-indigo-600"></i>
                จัดการสิทธิ์และผู้ใช้งานระบบ
              </h3>
              <button onclick="openAddUserModal()" class="px-4 py-2 bg-indigo-600 text-white text-xs font-semibold rounded-xl hover:bg-indigo-700 flex items-center gap-1.5 transition shadow-sm">
                <i data-lucide="plus" class="w-4 h-4"></i>
                เพิ่มผู้ใช้ใหม่
              </button>
            </div>

            <!-- Users list -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
              <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                  <thead>
                    <tr class="bg-slate-50 border-b border-slate-100 text-slate-500 text-xs font-semibold">
                      <th class="py-3 px-4">ชื่อผู้ใช้</th>
                      <th class="py-3 px-4">Username</th>
                      <th class="py-3 px-4">บทบาทสิทธิ์การใช้งาน</th>
                      <th class="py-3 px-4">กลุ่มงาน/ฝ่าย</th>
                      <th class="py-3 px-4 text-center">การจัดการ</th>
                    </tr>
                  </thead>
                  <tbody id="users-list" class="text-sm divide-y divide-slate-100 text-slate-600">
                    <!-- Dynamically populated -->
                  </tbody>
                </table>
              </div>
            </div>
          </section>

          <!-- VIEW 9: PROFILE VIEW (ดู/แก้ไข ข้อมูลตัวเอง) -->
          <section id="subview-profile" class="space-y-6 view-transition hidden">
            <div class="max-w-2xl mx-auto bg-white p-8 rounded-2xl border border-slate-100 shadow-sm">
              <div class="flex items-center space-x-4">
                <div class="w-16 h-16 rounded-2xl bg-indigo-600 text-white flex items-center justify-center font-bold text-2xl" id="profile-avatar">
                  U
                </div>
                <div>
                  <h3 class="text-xl font-bold" id="profile-full-name">ชื่อผู้ใช้งาน</h3>
                  <p class="text-sm text-slate-500" id="profile-role-badge">บทบาทของคุณ</p>
                </div>
              </div>

              <form id="profile-edit-form" class="mt-8 space-y-4">
                <div>
                  <label class="block text-sm font-semibold text-slate-700">ชื่อ-นามสกุล</label>
                  <input type="text" id="profile-name" required class="w-full px-4 py-2.5 mt-1 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500">
                </div>
                <div>
                  <label class="block text-sm font-semibold text-slate-700">กลุ่มสาระฯ / ฝ่ายงาน</label>
                  <input type="text" id="profile-dept" required class="w-full px-4 py-2.5 mt-1 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500">
                </div>
                <div>
                  <label class="block text-sm font-semibold text-slate-700">รหัสผ่านใหม่ (ปล่อยว่างหากต้องการใช้รหัสผ่านเดิม)</label>
                  <input type="password" id="profile-password" class="w-full px-4 py-2.5 mt-1 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="••••••••">
                </div>
                <button type="submit" class="w-full py-3 bg-indigo-600 text-white font-semibold rounded-xl hover:bg-indigo-700 shadow-md shadow-indigo-100 hover:shadow-lg transition">บันทึกประวัติส่วนตัว</button>
              </form>
            </div>
          </section>

        </div>

        <!-- BOTTOM NAVIGATION - Mobile View -->
        <nav class="md:hidden h-16 bg-white border-t border-slate-100 flex items-center justify-between px-6 z-20 sticky bottom-0">
          <button onclick="switchView('view-dashboard')" class="flex flex-col items-center justify-center text-slate-400 hover:text-indigo-600 transition flex-1 py-1">
            <i data-lucide="home" class="w-5 h-5"></i>
            <span class="text-[9px] mt-0.5">แดชบอร์ด</span>
          </button>
          <button onclick="switchView('view-inventory')" class="flex flex-col items-center justify-center text-slate-400 hover:text-indigo-600 transition flex-1 py-1">
            <i data-lucide="box" class="w-5 h-5"></i>
            <span class="text-[9px] mt-0.5">พัสดุ</span>
          </button>

          <!-- Middle Admin Toggle Panel Button (Visible to Admin Only) -->
          <div class="flex-1 flex justify-center py-1 relative z-30" id="mobile-admin-btn-container">
            <button onclick="toggleMobileAdminPanel()" class="w-12 h-12 bg-indigo-600 text-white rounded-full flex items-center justify-center shadow-lg hover:bg-indigo-700 active:scale-95 transition -translate-y-4">
              <i data-lucide="menu" class="w-6 h-6" id="mobile-admin-icon"></i>
            </button>
          </div>

          <button onclick="switchView('view-assets')" class="flex flex-col items-center justify-center text-slate-400 hover:text-indigo-600 transition flex-1 py-1">
            <i data-lucide="cpu" class="w-5 h-5"></i>
            <span class="text-[9px] mt-0.5">ครุภัณฑ์</span>
          </button>
          <button onclick="switchView('view-repairs')" class="flex flex-col items-center justify-center text-slate-400 hover:text-indigo-600 transition flex-1 py-1">
            <i data-lucide="wrench" class="w-5 h-5"></i>
            <span class="text-[9px] mt-0.5">แจ้งซ่อม</span>
          </button>
        </nav>

        <!-- Admin Back-office Rising Panel for Mobile Grid -->
        <div id="mobile-admin-panel" class="md:hidden fixed bottom-16 left-0 right-0 z-10 bg-slate-900 border-t border-slate-800 p-6 rounded-t-3xl shadow-2xl transition-all duration-300 transform translate-y-full flex flex-col space-y-4">
          <div class="flex justify-between items-center pb-2 border-b border-slate-850">
            <h4 class="text-sm font-bold text-white uppercase tracking-wider">เมนูจัดการระบบ (Admin)</h4>
            <button onclick="toggleMobileAdminPanel(false)" class="text-slate-400 hover:text-white">
              <i data-lucide="x" class="w-5 h-5"></i>
            </button>
          </div>
          <div class="grid grid-cols-3 gap-3">
            <button onclick="switchView('view-dashboard'); toggleMobileAdminPanel(false);" class="flex flex-col items-center justify-center p-3 bg-slate-800 rounded-2xl hover:bg-indigo-650 transition text-slate-200">
              <i data-lucide="pie-chart" class="w-6 h-6 text-indigo-400"></i>
              <span class="text-[10px] mt-1.5 text-center">Dashboard</span>
            </button>
            <button onclick="switchView('view-inventory'); toggleMobileAdminPanel(false);" class="flex flex-col items-center justify-center p-3 bg-slate-800 rounded-2xl hover:bg-indigo-650 transition text-slate-200">
              <i data-lucide="package" class="w-6 h-6 text-indigo-400"></i>
              <span class="text-[10px] mt-1.5 text-center">คลังพัสดุ</span>
            </button>
            <button onclick="switchView('view-assets'); toggleMobileAdminPanel(false);" class="flex flex-col items-center justify-center p-3 bg-slate-800 rounded-2xl hover:bg-indigo-650 transition text-slate-200">
              <i data-lucide="cpu" class="w-6 h-6 text-indigo-400"></i>
              <span class="text-[10px] mt-1.5 text-center">ครุภัณฑ์</span>
            </button>
            <button onclick="switchView('view-asset-checks'); toggleMobileAdminPanel(false);" class="flex flex-col items-center justify-center p-3 bg-slate-800 rounded-2xl hover:bg-indigo-650 transition text-slate-200">
              <i data-lucide="clipboard-check" class="w-6 h-6 text-indigo-400"></i>
              <span class="text-[10px] mt-1.5 text-center">ตรวจประจำปี</span>
            </button>
            <button onclick="switchView('view-repairs'); toggleMobileAdminPanel(false);" class="flex flex-col items-center justify-center p-3 bg-slate-800 rounded-2xl hover:bg-indigo-650 transition text-slate-200">
              <i data-lucide="wrench" class="w-6 h-6 text-indigo-400"></i>
              <span class="text-[10px] mt-1.5 text-center">แจ้งซ่อม</span>
            </button>
            <button onclick="switchView('view-procurements'); toggleMobileAdminPanel(false);" class="flex flex-col items-center justify-center p-3 bg-slate-800 rounded-2xl hover:bg-indigo-650 transition text-slate-200">
              <i data-lucide="file-text" class="w-6 h-6 text-indigo-400"></i>
              <span class="text-[10px] mt-1.5 text-center">จัดซื้อจัดจ้าง</span>
            </button>
            <button onclick="switchView('view-reports'); toggleMobileAdminPanel(false);" class="flex flex-col items-center justify-center p-3 bg-slate-800 rounded-2xl hover:bg-indigo-650 transition text-slate-200">
              <i data-lucide="trending-up" class="w-6 h-6 text-indigo-400"></i>
              <span class="text-[10px] mt-1.5 text-center">รายงาน</span>
            </button>
            <button onclick="switchView('view-users'); toggleMobileAdminPanel(false);" class="flex flex-col items-center justify-center p-3 bg-slate-800 rounded-2xl hover:bg-indigo-650 transition text-slate-200">
              <i data-lucide="users" class="w-6 h-6 text-indigo-400"></i>
              <span class="text-[10px] mt-1.5 text-center">ผู้ใช้งาน</span>
            </button>
            <button onclick="confirmLogout(); toggleMobileAdminPanel(false);" class="flex flex-col items-center justify-center p-3 bg-slate-800 rounded-2xl hover:bg-red-900 transition text-slate-200">
              <i data-lucide="log-out" class="w-6 h-6 text-red-400"></i>
              <span class="text-[10px] mt-1.5 text-center text-red-300">ออกระบบ</span>
            </button>
          </div>
        </div>

      </main>
    </div>

  </div>

  <!-- ==========================================================
       MODALS SECTION
       ========================================================== -->

  <!-- Modal: Confirm Logout -->
  <div id="logout-confirm-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/50 backdrop-blur-sm hidden">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm p-6 mx-4">
      <div class="text-center">
        <div class="w-12 h-12 bg-red-50 text-red-600 flex items-center justify-center rounded-full mx-auto">
          <i data-lucide="log-out" class="w-6 h-6"></i>
        </div>
        <h4 class="text-lg font-bold text-slate-900 mt-4">ออกจากระบบ ?</h4>
        <p class="text-sm text-slate-500 mt-2">ยืนยันว่าต้องการออกจากระบบใช่หรือไม่ ข้อมูลเซสชันจะถูกลบ</p>
      </div>
      <div class="mt-6 flex space-x-3">
        <button onclick="hideLogoutConfirm()" class="flex-1 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 text-sm font-semibold rounded-xl transition">ยกเลิก</button>
        <button onclick="logout()" class="flex-1 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-xl transition">ยืนยันออกจากระบบ</button>
      </div>
    </div>
  </div>

  <!-- Modal: Receive Stock (พัสดุเข้า) -->
  <div id="modal-receive-stock" class="fixed inset-0 z-40 flex items-center justify-center bg-slate-900/50 backdrop-blur-sm hidden">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-lg p-6 mx-4 max-h-[90vh] overflow-y-auto custom-scrollbar">
      <div class="flex justify-between items-center pb-3 border-b border-slate-100">
        <h3 class="text-lg font-bold text-slate-800 flex items-center gap-2">
          <i data-lucide="package-plus" class="w-5 h-5 text-indigo-600"></i>
          รับพัสดุ/ซื้อใหม่เข้าคลัง
        </h3>
        <button onclick="closeReceiveStockModal()" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
      </div>
      <form id="form-receive-stock" class="mt-4 space-y-4">
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">เลือกประเภทการรับเข้า</label>
          <select id="receive-log-type" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
            <option value="purchase">ซื้อใหม่ (จากโครงการ/ร้านค้า)</option>
            <option value="donation">รับบริจาค</option>
            <option value="transfer">โอนย้ายเข้า</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">พัสดุในคลัง</label>
          <select id="receive-inventory-id" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
            <!-- Loaded via JS -->
          </select>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">จำนวนรับเข้า</label>
            <input type="number" id="receive-quantity" required min="1" class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">ราคาต่อหน่วย (บาท)</label>
            <input type="number" id="receive-price" required min="0" step="0.01" class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">ผู้ขาย / แหล่งที่มา</label>
          <input type="text" id="receive-seller" class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none" placeholder="เช่น บจก. เครื่องเขียนไทย">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">เลขที่ใบสั่งซื้อ (PO) (ถ้ามี)</label>
          <input type="text" id="receive-po" class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none" placeholder="เช่น PO-2569/001">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">วันที่รับเข้า</label>
          <input type="date" id="receive-date" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div class="pt-4 border-t border-slate-100 flex space-x-3">
          <button type="button" onclick="closeReceiveStockModal()" class="flex-1 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold rounded-xl transition">ยกเลิก</button>
          <button type="submit" class="flex-1 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition">บันทึกรับเข้า</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: Request Borrow (ขอเบิกพัสดุ) -->
  <div id="modal-request-borrow" class="fixed inset-0 z-40 flex items-center justify-center bg-slate-900/50 backdrop-blur-sm hidden">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-lg p-6 mx-4 max-h-[90vh] overflow-y-auto custom-scrollbar">
      <div class="flex justify-between items-center pb-3 border-b border-slate-100">
        <h3 class="text-lg font-bold text-slate-800 flex items-center gap-2">
          <i data-lucide="shopping-bag" class="w-5 h-5 text-indigo-600"></i>
          ยื่นคำขอเบิกพัสดุ (วัสดุสิ้นเปลือง)
        </h3>
        <button onclick="closeRequestBorrowModal()" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
      </div>
      <form id="form-request-borrow" class="mt-4 space-y-4">
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">ค้นหาพัสดุเพื่อเบิก</label>
          <select id="borrow-inventory-id" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
            <!-- Loaded dynamically -->
          </select>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">จำนวนที่ต้องการเบิก</label>
            <input type="number" id="borrow-quantity" required min="1" class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">วันที่ขอเบิก</label>
            <input type="date" id="borrow-date" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">ผู้เบิก (ชื่ออาจารย์)</label>
          <input type="text" id="borrow-borrower" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">กลุ่มสาระการเรียนรู้ / แผนก</label>
          <input type="text" id="borrow-department" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div class="pt-4 border-t border-slate-100 flex space-x-3">
          <button type="button" onclick="closeRequestBorrowModal()" class="flex-1 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold rounded-xl transition">ยกเลิก</button>
          <button type="submit" class="flex-1 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition">ส่งใบขอเบิก</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: Return Stock (คืนพัสดุที่เบิกเกิน) -->
  <div id="modal-return-stock" class="fixed inset-0 z-40 flex items-center justify-center bg-slate-900/50 backdrop-blur-sm hidden">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-lg p-6 mx-4 max-h-[90vh] overflow-y-auto custom-scrollbar">
      <div class="flex justify-between items-center pb-3 border-b border-slate-100">
        <h3 class="text-lg font-bold text-slate-800 flex items-center gap-2">
          <i data-lucide="refresh-cw" class="w-5 h-5 text-indigo-600"></i>
          ส่งคืนพัสดุ (กรณีเบิกเกิน)
        </h3>
        <button onclick="closeReturnStockModal()" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
      </div>
      <form id="form-return-stock" class="mt-4 space-y-4">
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">เลือกใบเบิกเดิมที่ต้องการคืนพัสดุบางส่วน</label>
          <select id="return-request-id" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none text-xs">
            <!-- Loaded dynamically via JS -->
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">จำนวนที่ต้องการส่งคืนเข้าคลัง</label>
          <input type="number" id="return-quantity" required min="1" class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div class="pt-4 border-t border-slate-100 flex space-x-3">
          <button type="button" onclick="closeReturnStockModal()" class="flex-1 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold rounded-xl transition">ยกเลิก</button>
          <button type="submit" class="flex-1 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition">ส่งคืนคลังและเพิ่มยอดคงเหลือ</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: Add/Edit Asset (เพิ่ม/แก้ไขครุภัณฑ์) -->
  <div id="modal-add-asset" class="fixed inset-0 z-40 flex items-center justify-center bg-slate-900/50 backdrop-blur-sm hidden">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-xl p-6 mx-4 max-h-[90vh] overflow-y-auto custom-scrollbar">
      <div class="flex justify-between items-center pb-3 border-b border-slate-100">
        <h3 id="asset-modal-title" class="text-lg font-bold text-slate-800 flex items-center gap-2">
          <i data-lucide="cpu" class="w-5 h-5 text-indigo-600"></i>
          เพิ่มครุภัณฑ์ใหม่
        </h3>
        <button onclick="closeAddAssetModal()" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
      </div>
      <form id="form-add-asset" class="mt-4 space-y-4">
        <input type="hidden" id="asset-edit-id">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">เลขครุภัณฑ์ (เว้นว่างเพื่อ Auto Generate)</label>
            <input type="text" id="asset-code" class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none placeholder-slate-300" placeholder="ASSET-2569-xxxx">
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">ชื่อครุภัณฑ์</label>
            <input type="text" id="asset-name" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none" placeholder="เช่น Computer Lab 01">
          </div>
        </div>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">ยี่ห้อ</label>
            <input type="text" id="asset-brand" class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">รุ่น</label>
            <input type="text" id="asset-model" class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">Serial Number</label>
            <input type="text" id="asset-serial" class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
        </div>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">ราคาครุภัณฑ์ (บาท)</label>
            <input type="number" id="asset-price" required min="0" step="0.01" class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">ปีงบประมาณ</label>
            <input type="text" id="asset-fiscal-year" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none" placeholder="เช่น 2569">
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">แหล่งเงินทุน</label>
            <input type="text" id="asset-funding" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none" placeholder="เช่น งบประมาณแผ่นดิน/บริจาค">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">ห้อง/สถานที่ติดตั้ง</label>
            <input type="text" id="asset-room" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">ผู้ดูแลรับผิดชอบ</label>
            <input type="text" id="asset-responsible" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">สถานะ</label>
            <select id="asset-status" class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
              <option value="ปกติ">ใช้งานปกติ</option>
              <option value="ชำรุด">ชำรุด</option>
              <option value="ส่งซ่อม">ส่งซ่อม</option>
              <option value="จำหน่าย">จำหน่าย</option>
              <option value="สูญหาย">สูญหาย</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">อัปโหลดรูปภาพครุภัณฑ์</label>
            <input type="file" id="asset-image-file" accept="image/*" class="w-full text-xs text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 cursor-pointer mt-1">
          </div>
        </div>
        <div class="pt-4 border-t border-slate-100 flex space-x-3">
          <button type="button" onclick="closeAddAssetModal()" class="flex-1 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold rounded-xl transition">ยกเลิก</button>
          <button type="submit" class="flex-1 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition">บันทึกครุภัณฑ์</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: View Asset QR & Details & Stickers -->
  <div id="modal-view-asset" class="fixed inset-0 z-40 flex items-center justify-center bg-slate-900/50 backdrop-blur-sm hidden">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-2xl p-6 mx-4 max-h-[90vh] overflow-y-auto custom-scrollbar">
      <div class="flex justify-between items-center pb-3 border-b border-slate-100">
        <h3 class="text-lg font-bold text-slate-800 flex items-center gap-2">
          <i data-lucide="cpu" class="w-5 h-5 text-indigo-600"></i>
          รายละเอียดครุภัณฑ์และพิมพ์สติ๊กเกอร์
        </h3>
        <button onclick="closeViewAssetModal()" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
      </div>
      
      <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Details & Repair History -->
        <div class="space-y-4">
          <!-- Image Container with failure handler -->
          <div class="relative w-full h-48 bg-slate-100 rounded-xl overflow-hidden flex items-center justify-center">
            <img id="detail-asset-image" src="" alt="ภาพครุภัณฑ์" class="w-full h-full object-cover hidden" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
            <div class="absolute inset-0 flex flex-col items-center justify-center text-slate-400">
              <i data-lucide="image-off" class="w-10 h-10 mb-2"></i>
              <span class="text-xs">ไม่มีรูปภาพแสดง</span>
            </div>
          </div>
          <div>
            <h4 id="detail-asset-name" class="text-lg font-bold text-slate-900">-</h4>
            <p id="detail-asset-code" class="text-sm text-indigo-600 font-semibold">-</p>
          </div>
          <div class="grid grid-cols-2 gap-2 text-xs text-slate-600">
            <div><strong>สถานที่ติดตั้ง:</strong> <span id="detail-asset-room">-</span></div>
            <div><strong>ผู้รับผิดชอบ:</strong> <span id="detail-asset-responsible">-</span></div>
            <div><strong>ยี่ห้อ/รุ่น:</strong> <span id="detail-asset-brand-model">-</span></div>
            <div><strong>ราคา:</strong> <span id="detail-asset-price">-</span> บาท</div>
            <div><strong>ปีงบประมาณ:</strong> <span id="detail-asset-fiscal">-</span></div>
            <div><strong>สถานะ:</strong> <span id="detail-asset-status" class="font-bold text-indigo-600">-</span></div>
          </div>

          <!-- Repair history list -->
          <div class="pt-4 border-t border-slate-100">
            <h5 class="text-xs font-bold text-slate-700 uppercase tracking-wider mb-2">ประวัติการซ่อมบำรุง</h5>
            <div id="detail-asset-repair-history" class="space-y-2 text-xs max-h-32 overflow-y-auto custom-scrollbar">
              <p class="text-slate-400">ไม่มีประวัติการซ่อม</p>
            </div>
          </div>
        </div>

        <!-- QR Code & Print Options -->
        <div class="flex flex-col items-center justify-center p-4 bg-slate-50 rounded-2xl border border-slate-150 text-center">
          <h5 class="text-xs font-bold text-slate-700 uppercase mb-4">สติ๊กเกอร์ติดครุภัณฑ์ (QR / Barcode)</h5>
          
          <div class="bg-white p-4 rounded-xl shadow-sm border border-slate-100 flex flex-col items-center" id="printable-sticker-area">
            <canvas id="detail-asset-qr-canvas" class="w-32 h-32"></canvas>
            <p id="detail-asset-qr-text" class="text-xs font-bold text-slate-900 mt-2">-</p>
            <p id="detail-asset-qr-label" class="text-[10px] text-slate-500 font-medium"></p>
            <canvas id="detail-asset-barcode-canvas" class="mt-2" style="max-height: 40px;"></canvas>
          </div>

          <!-- Sticker Formats -->
          <div class="w-full mt-6 space-y-2">
            <label class="block text-[10px] font-semibold text-slate-600 uppercase text-left">เลือกขนาดสำหรับส่งพิมพ์สติ๊กเกอร์</label>
            <div class="grid grid-cols-3 gap-2">
              <button onclick="printSticker('a4')" class="py-2 bg-indigo-600 text-white text-xs font-semibold rounded-xl hover:bg-indigo-700 transition">A4 (หลายชิ้น)</button>
              <button onclick="printSticker('3x5')" class="py-2 bg-slate-800 text-white text-xs font-semibold rounded-xl hover:bg-slate-900 transition">3 x 5 ซม.</button>
              <button onclick="printSticker('5x5')" class="py-2 bg-slate-800 text-white text-xs font-semibold rounded-xl hover:bg-slate-900 transition">5 x 5 ซม.</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal: Annual Inspect Detail & Form (Annual Inspection) -->
  <div id="modal-inspect-asset-action" class="fixed inset-0 z-40 flex items-center justify-center bg-slate-900/50 backdrop-blur-sm hidden">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm p-6 mx-4">
      <div class="flex justify-between items-center pb-3 border-b border-slate-100">
        <h3 class="text-lg font-bold text-slate-800">บันทึกการตรวจสอบครุภัณฑ์</h3>
        <button onclick="closeInspectAssetModal()" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
      </div>
      <div class="mt-4 space-y-4">
        <div>
          <h4 id="inspect-asset-name" class="font-bold text-slate-800">-</h4>
          <p id="inspect-asset-code" class="text-xs text-indigo-600 font-semibold">-</p>
        </div>
        <div class="space-y-2">
          <label class="block text-xs font-semibold text-slate-600 uppercase">กรุณาเลือกผลการตรวจ</label>
          <div class="grid grid-cols-3 gap-2">
            <button onclick="submitAssetInspection('พบครบ')" class="py-3 bg-emerald-50 border border-emerald-200 text-emerald-700 hover:bg-emerald-100 text-xs font-bold rounded-xl transition flex flex-col items-center justify-center">
              <i data-lucide="check-circle" class="w-5 h-5 mb-1"></i>
              พบครบ
            </button>
            <button onclick="submitAssetInspection('สูญหาย')" class="py-3 bg-rose-50 border border-rose-200 text-rose-700 hover:bg-rose-100 text-xs font-bold rounded-xl transition flex flex-col items-center justify-center">
              <i data-lucide="help-circle" class="w-5 h-5 mb-1"></i>
              สูญหาย
            </button>
            <button onclick="submitAssetInspection('ชำรุด')" class="py-3 bg-amber-50 border border-amber-200 text-amber-700 hover:bg-amber-100 text-xs font-bold rounded-xl transition flex flex-col items-center justify-center">
              <i data-lucide="alert-triangle" class="w-5 h-5 mb-1"></i>
              ชำรุด
            </button>
          </div>
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">หมายเหตุเพิ่มเติม</label>
          <textarea id="inspect-notes" class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none text-xs" rows="2" placeholder="ระบุรายละเอียด เช่น อุปกรณ์เสริมสูญหาย หรือต้องซ่อมแซมจุดใด..."></textarea>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal: Report Repair Form (แจ้งซ่อม) -->
  <div id="modal-report-repair-form" class="fixed inset-0 z-40 flex items-center justify-center bg-slate-900/50 backdrop-blur-sm hidden">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6 mx-4">
      <div class="flex justify-between items-center pb-3 border-b border-slate-100">
        <h3 class="text-lg font-bold text-slate-800 flex items-center gap-1.5">
          <i data-lucide="wrench" class="w-5 h-5 text-indigo-600"></i>
          แจ้งข้อมูลขัดข้อง / แจ้งซ่อมครุภัณฑ์
        </h3>
        <button onclick="closeReportRepairModal()" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
      </div>
      <form id="form-report-repair" class="mt-4 space-y-4">
        <input type="hidden" id="repair-asset-id">
        <div>
          <h4 id="repair-asset-name-label" class="font-bold text-slate-800">-</h4>
          <p id="repair-asset-code-label" class="text-xs text-indigo-600 font-semibold">-</p>
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">รายละเอียดอาการชำรุด / ปัญหาที่พบ</label>
          <textarea id="repair-description" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none text-xs" rows="3" placeholder="เช่น เครื่องฉายภาพไม่ขึ้นรูป, พัดลมไม่หมุน, ภาพเบลอ..."></textarea>
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">อัปโหลดภาพถ่ายแนบการส่งซ่อม</label>
          <input type="file" id="repair-image-file" accept="image/*" class="w-full text-xs text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 cursor-pointer mt-1">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">ชื่อครูผู้แจ้ง</label>
          <input type="text" id="repair-reporter" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none text-xs">
        </div>
        <div class="pt-4 border-t border-slate-100 flex space-x-3">
          <button type="button" onclick="closeReportRepairModal()" class="flex-1 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold rounded-xl transition text-xs">ยกเลิก</button>
          <button type="submit" class="flex-1 py-2 bg-rose-600 hover:bg-rose-700 text-white font-semibold rounded-xl transition text-xs">ส่งแจ้งซ่อมบำรุง</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: QR Code Scanner Camera -->
  <div id="modal-qr-scanner" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/60 backdrop-blur-sm hidden">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6 mx-4">
      <div class="flex justify-between items-center pb-3 border-b border-slate-100">
        <h3 class="text-lg font-bold text-slate-800 flex items-center gap-1.5">
          <i data-lucide="scan-line" class="w-5 h-5 text-indigo-600"></i>
          สแกน QR Code จากโทรศัพท์มือถือ
        </h3>
        <button onclick="closeScanQrModal()" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
      </div>
      <div class="mt-4 flex flex-col items-center">
        <div id="qr-reader" class="w-full bg-slate-100 rounded-xl overflow-hidden" style="min-height: 250px;"></div>
        <p class="text-xs text-slate-500 mt-3 text-center">หันกล้องไปที่ QR Code บนพัสดุหรือครุภัณฑ์เพื่อตรวจสอบหรือแจ้งซ่อม</p>
      </div>
    </div>
  </div>

  <!-- Modal: Add Procurement (จัดซื้อจัดจ้าง) -->
  <div id="modal-add-procurement" class="fixed inset-0 z-40 flex items-center justify-center bg-slate-900/50 backdrop-blur-sm hidden">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-2xl p-6 mx-4 max-h-[90vh] overflow-y-auto custom-scrollbar">
      <div class="flex justify-between items-center pb-3 border-b border-slate-100">
        <h3 class="text-lg font-bold text-slate-800 flex items-center gap-2">
          <i data-lucide="file-plus-2" class="w-5 h-5 text-indigo-600"></i>
          บันทึกโครงการจัดซื้อจัดจ้าง
        </h3>
        <button onclick="closeAddProcurementModal()" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
      </div>
      <form id="form-add-procurement" class="mt-4 space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">ชื่อโครงการจัดซื้อจัดจ้าง</label>
            <input type="text" id="procure-name" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none" placeholder="เช่น จัดซื้อหมึกพิมพ์และเครื่องเขียน ภาคเรียน 1/2569">
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">ปีงบประมาณ</label>
            <input type="text" id="procure-fiscal" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none" placeholder="เช่น 2569">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">ผู้ขาย / บริษัทคู่สัญญา</label>
            <input type="text" id="procure-seller" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none" placeholder="บจก. ซัพพลายคอร์ป">
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">อัปโหลดใบเสนอราคา (Quotation)</label>
            <input type="file" id="procure-file-quotation" accept="image/*,application/pdf" class="w-full text-xs text-slate-500 file:mr-4 file:py-1.5 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 cursor-pointer mt-1">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">อัปโหลดใบสั่งซื้อ (PO)</label>
            <input type="file" id="procure-file-po" accept="image/*,application/pdf" class="w-full text-xs text-slate-500 file:mr-4 file:py-1.5 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 cursor-pointer mt-1">
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase">อัปโหลดใบตรวจรับสินค้า</label>
            <input type="file" id="procure-file-receive" accept="image/*,application/pdf" class="w-full text-xs text-slate-500 file:mr-4 file:py-1.5 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 cursor-pointer mt-1">
          </div>
        </div>

        <!-- Procurement Items list -->
        <div class="pt-4 border-t border-slate-100">
          <div class="flex justify-between items-center mb-2">
            <h4 class="text-xs font-bold text-slate-700 uppercase">รายการพัสดุที่จะนำเข้าคลัง (เมื่ออนุมัติ)</h4>
            <button type="button" onclick="addProcureItemRow()" class="px-2 py-1 bg-indigo-50 text-indigo-700 hover:bg-indigo-100 text-xs font-semibold rounded-lg flex items-center gap-1 transition">
              <i data-lucide="plus" class="w-3.5 h-3.5"></i>เพิ่มแถวสินค้า
            </button>
          </div>
          <div id="procure-items-list-container" class="space-y-2 max-h-48 overflow-y-auto custom-scrollbar pr-1">
            <!-- Dynamically adding rows -->
          </div>
        </div>

        <div class="pt-4 border-t border-slate-100 flex space-x-3">
          <button type="button" onclick="closeAddProcurementModal()" class="flex-1 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold rounded-xl transition">ยกเลิก</button>
          <button type="submit" class="flex-1 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition">สร้างโครงการ</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: Add User (เพิ่ม/แก้ไขผู้ใช้งานระบบ) -->
  <div id="modal-add-user" class="fixed inset-0 z-40 flex items-center justify-center bg-slate-900/50 backdrop-blur-sm hidden">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6 mx-4">
      <div class="flex justify-between items-center pb-3 border-b border-slate-100">
        <h3 id="user-modal-title" class="text-lg font-bold text-slate-800">เพิ่มผู้ใช้ใหม่ในระบบ</h3>
        <button onclick="closeAddUserModal()" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
      </div>
      <form id="form-add-user" class="mt-4 space-y-4">
        <input type="hidden" id="user-edit-id">
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">ชื่อ-นามสกุลจริง</label>
          <input type="text" id="user-full-name" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">กลุ่มงาน / แผนก</label>
          <input type="text" id="user-department" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">ชื่อผู้ใช้งาน (Username)</label>
          <input type="text" id="user-username" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">รหัสผ่าน (Password)</label>
          <input type="password" id="user-password" required class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-600 uppercase">สิทธิ์และบทบาท</label>
          <select id="user-role" class="w-full px-4 py-2 mt-1 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
            <option value="admin">ผู้ดูแลระบบ (Admin)</option>
            <option value="officer">เจ้าหน้าที่พัสดุ (Officer)</option>
            <option value="teacher">ครูผู้ใช้ทั่วไป (Teacher)</option>
            <option value="executive">ผู้บริหาร (Executive)</option>
          </select>
        </div>
        <div class="pt-4 border-t border-slate-100 flex space-x-3">
          <button type="button" onclick="closeAddUserModal()" class="flex-1 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold rounded-xl transition">ยกเลิก</button>
          <button type="submit" class="flex-1 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition">บันทึกข้อมูลผู้ใช้</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Javascript Logic -->
  <script>
    // System Configurations and Global State
    let dbClient = null;
    let currentUser = null;
    let html5QrScanner = null;
    let qrScannerCallbackMode = ''; // 'view_asset', 'annual_check', 'report_repair'
    
    // Cached DB data
    let cacheInventory = [];
    let cacheAssets = [];
    let cacheUsers = [];
    let cacheRepairs = [];
    let cacheProcurements = [];
    let cacheRequests = [];

    // Chart references
    let monthlyChart = null;

    // PWA Service Worker Registration
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('./sw.js')
          .then((reg) => console.log('Service Worker registered successfully!', reg))
          .catch((err) => console.warn('Service worker registration failed:', err));
      });
    }

    // App Initialization
    window.addEventListener('DOMContentLoaded', async () => {
      // Initialize Lucide Icons
      lucide.createIcons();
      
      // Auto connection from localStorage
      const savedSbUrl = localStorage.getItem('school_sb_url');
      const savedSbKey = localStorage.getItem('school_sb_key');
      
      if (savedSbUrl && savedSbKey) {
        initSupabase(savedSbUrl, savedSbKey);
      } else {
        // Show connect modal if missing
        toggleConfigModal(true);
      }
      
      // Check if logged in in this session
      const savedUser = sessionStorage.getItem('school_user');
      if (savedUser) {
        currentUser = JSON.parse(savedUser);
        onUserAuthenticated();
      } else {
        // Show landing page
        showView('view-landing');
        if (dbClient) {
          updateLandingStats();
        }
      }
    });

    // Supabase Connection initialization
    function initSupabase(url, key) {
      try {
        dbClient = supabase.createClient(url, key);
        console.log('Supabase connection initialized successfully!');
        localStorage.setItem('school_sb_url', url);
        localStorage.setItem('school_sb_key', key);
        
        // Hide config modal and reload dashboard if authenticated
        toggleConfigModal(false);
        showToast('เชื่อมต่อฐานข้อมูลสำเร็จ', 'success');
        
        if (currentUser) {
          onUserAuthenticated();
        } else {
          updateLandingStats();
        }
      } catch (e) {
        console.error(e);
        showToast('การเชื่อมต่อล้มเหลว ตรวจสอบ URL / Key อีกครั้ง', 'danger');
        toggleConfigModal(true);
      }
    }

    function toggleConfigModal(show = true) {
      const modal = document.getElementById('supabase-config-modal');
      const urlInput = document.getElementById('config-sb-url');
      const keyInput = document.getElementById('config-sb-key');
      
      if (show) {
        urlInput.value = localStorage.getItem('school_sb_url') || '';
        keyInput.value = localStorage.getItem('school_sb_key') || '';
        modal.classList.remove('hidden');
      } else {
        modal.classList.add('hidden');
      }
    }

    document.getElementById('supabase-config-form').addEventListener('submit', (e) => {
      e.preventDefault();
      const url = document.getElementById('config-sb-url').value.trim();
      const key = document.getElementById('config-sb-key').value.trim();
      initSupabase(url, key);
    });

    // Landing Stats updater (Offline Safe)
    async function updateLandingStats() {
      if (!dbClient) return;
      try {
        const { data: inv, error: err1 } = await dbClient.from('inventory').select('*');
        const { data: ast, error: err2 } = await dbClient.from('assets').select('*');
        
        if (err1 || err2) throw new Error("DB Fetch failed");
        
        document.getElementById('landing-count-inventory').innerText = inv ? inv.length : 0;
        document.getElementById('landing-count-assets').innerText = ast ? ast.length : 0;
        
        const damaged = ast ? ast.filter(a => a.status === 'ชำรุด').length : 0;
        document.getElementById('landing-count-damaged').innerText = damaged;
        
        const totalVal = ast ? ast.reduce((sum, item) => sum + (Number(item.price) || 0), 0) : 0;
        document.getElementById('landing-total-value').innerText = totalVal.toLocaleString() + ' ฿';
      } catch (e) {
        console.warn('Could not fetch stats for landing page:', e);
      }
    }

    // Modal Control: Login
    function showLoginModal() {
      if (!dbClient) {
        showToast('กรุณาเชื่อมต่อฐานข้อมูลก่อนเข้าสู่ระบบ', 'warning');
        toggleConfigModal(true);
        return;
      }
      const m = document.getElementById('login-modal');
      const mc = document.getElementById('login-modal-content');
      m.classList.remove('hidden');
      setTimeout(() => {
        mc.classList.remove('scale-95', 'opacity-0');
        mc.classList.add('scale-100', 'opacity-100');
      }, 50);
    }

    function hideLoginModal() {
      const m = document.getElementById('login-modal');
      const mc = document.getElementById('login-modal-content');
      mc.classList.remove('scale-100', 'opacity-100');
      mc.classList.add('scale-95', 'opacity-0');
      setTimeout(() => m.classList.add('hidden'), 300);
    }

    // Custom Login Form Handler
    document.getElementById('login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const user = document.getElementById('login-username').value.trim();
      const pass = document.getElementById('login-password').value.trim();
      
      showLoader(true);
      try {
        const { data, error } = await dbClient
          .from('users')
          .select('*')
          .eq('username', user)
          .eq('password', pass)
          .single();
          
        if (error || !data) {
          throw new Error('ชื่อผู้ใช้หรือรหัสผ่านไม่ถูกต้อง');
        }
        
        currentUser = data;
        sessionStorage.setItem('school_user', JSON.stringify(currentUser));
        hideLoginModal();
        showToast(`ยินดีต้อนรับคุณ ${currentUser.name}`, 'success');
        onUserAuthenticated();
      } catch (err) {
        showToast(err.message || 'การเข้าสู่ระบบล้มเหลว', 'danger');
      } finally {
        showLoader(false);
      }
    });

    // Logged In Flow setup
    async function onUserAuthenticated() {
      // Hide guest view, show app layout
      document.getElementById('view-landing').classList.add('hidden');
      document.getElementById('view-app').classList.remove('hidden');
      
      // Update UI components
      document.getElementById('desktop-user-name').innerText = currentUser.name;
      document.getElementById('desktop-user-role').innerText = getRoleLabel(currentUser.role);
      document.getElementById('desktop-avatar').innerText = currentUser.name.charAt(0).toUpperCase();
      document.getElementById('app-user-role-badge').innerText = getRoleLabel(currentUser.role);

      // Render role-based desktop navigation
      buildSidebarNavigation();
      
      // Load all cached data
      await refreshAllData();
      
      // Show default view
      switchView('view-dashboard');
    }

    function getRoleLabel(role) {
      const labels = {
        'admin': 'ผู้ดูแลระบบ (Admin)',
        'officer': 'เจ้าหน้าที่พัสดุ (Officer)',
        'teacher': 'ครูผู้สอน (Teacher)',
        'executive': 'ผู้บริหาร (Executive)'
      };
      return labels[role] || 'ครูผู้สอน';
    }

    // Navigation Menu builder
    function buildSidebarNavigation() {
      const nav = document.getElementById('desktop-nav');
      nav.innerHTML = '';
      
      // Core menus for everyone
      const menus = [
        { id: 'view-dashboard', label: 'แดชบอร์ดสรุปงาน', icon: 'pie-chart', roles: ['admin', 'officer', 'teacher', 'executive'] },
        { id: 'view-inventory', label: 'ระบบจัดการพัสดุ', icon: 'package', roles: ['admin', 'officer', 'teacher', 'executive'] },
        { id: 'view-assets', label: 'ระบบทะเบียนครุภัณฑ์', icon: 'cpu', roles: ['admin', 'officer', 'teacher', 'executive'] },
        { id: 'view-asset-checks', label: 'ตรวจสอบครุภัณฑ์ประจำปี', icon: 'clipboard-check', roles: ['admin', 'officer', 'teacher', 'executive'] },
        { id: 'view-repairs', label: 'ระบบแจ้งซ่อมบำรุง', icon: 'wrench', roles: ['admin', 'officer', 'teacher', 'executive'] },
        { id: 'view-procurements', label: 'ระบบจัดซื้อจัดจ้าง', icon: 'file-text', roles: ['admin', 'officer', 'executive'] },
        { id: 'view-reports', label: 'ระบบรายงาน & วิเคราะห์', icon: 'trending-up', roles: ['admin', 'officer', 'executive'] },
        { id: 'view-users', label: 'จัดการสิทธิ์ผู้ใช้งาน', icon: 'users', roles: ['admin'] },
        { id: 'view-profile', label: 'ประวัติส่วนตัว', icon: 'user', roles: ['admin', 'officer', 'teacher', 'executive'] }
      ];

      // Hide or show special bottom mobile elements
      const mobBtnContainer = document.getElementById('mobile-admin-btn-container');
      if (currentUser.role === 'admin') {
        mobBtnContainer.style.display = 'flex';
      } else {
        mobBtnContainer.style.display = 'none';
      }

      menus.forEach(menu => {
        if (menu.roles.includes(currentUser.role)) {
          const btn = document.createElement('button');
          btn.onclick = () => switchView(menu.id);
          btn.className = `w-full flex items-center space-x-3 px-4 py-2.5 text-slate-400 hover:text-white hover:bg-slate-800 rounded-xl transition mb-1 text-left nav-btn-item`;
          btn.setAttribute('data-target', menu.id);
          btn.innerHTML = `
            <i data-lucide="${menu.icon}" class="w-5 h-5 flex-shrink-0"></i>
            <span class="text-sm font-semibold">${menu.label}</span>
          `;
          nav.appendChild(btn);
        }
      });
      
      lucide.createIcons();
    }

    // View Switching Logic (SPA)
    function switchView(viewId) {
      // Breadcrumb mapping
      const breadcrumbs = {
        'view-dashboard': 'แดชบอร์ดผู้บริหาร',
        'view-inventory': 'ระบบจัดการพัสดุ (วัสดุสิ้นเปลือง)',
        'view-assets': 'ระบบจัดการทะเบียนครุภัณฑ์',
        'view-asset-checks': 'ตรวจสอบครุภัณฑ์ประจำปี',
        'view-repairs': 'ระบบแจ้งซ่อมและบำรุงรักษา',
        'view-procurements': 'ระบบจัดซื้อจัดจ้างและการนำเข้า',
        'view-reports': 'ระบบรายงานสถิติและตัววัดผล',
        'view-users': 'ระบบจัดการข้อมูลพนักงาน / ครูผู้สอน',
        'view-profile': 'ข้อมูลประวัติส่วนตัว'
      };
      
      const title = breadcrumbs[viewId] || 'ระบบงานพัสดุ';
      document.getElementById('breadcrumb-current').innerText = title;
      
      // Hide all subviews
      const sections = ['subview-dashboard', 'subview-inventory', 'subview-assets', 'subview-asset-checks', 'subview-asset-repairs', 'subview-procurements', 'subview-reports', 'subview-user-management', 'subview-profile'];
      sections.forEach(sec => document.getElementById(sec).classList.add('hidden'));
      
      // Map viewId to section element
      let targetSection = 'subview-dashboard';
      if (viewId === 'view-inventory') targetSection = 'subview-inventory';
      else if (viewId === 'view-assets') targetSection = 'subview-assets';
      else if (viewId === 'view-asset-checks') targetSection = 'subview-asset-checks';
      else if (viewId === 'view-repairs') targetSection = 'subview-asset-repairs';
      else if (viewId === 'view-procurements') targetSection = 'subview-procurements';
      else if (viewId === 'view-reports') targetSection = 'subview-reports';
      else if (viewId === 'view-users') targetSection = 'subview-user-management';
      else if (viewId === 'view-profile') targetSection = 'subview-profile';
      
      const secEl = document.getElementById(targetSection);
      secEl.classList.remove('hidden');
      
      // Update sidebar active states
      const navButtons = document.querySelectorAll('.nav-btn-item');
      navButtons.forEach(btn => {
        if (btn.getAttribute('data-target') === viewId) {
          btn.classList.add('bg-indigo-600', 'text-white');
          btn.classList.remove('text-slate-400');
        } else {
          btn.classList.remove('bg-indigo-600', 'text-white');
          btn.classList.add('text-slate-400');
        }
      });

      // Special page load hooks
      if (viewId === 'view-dashboard') {
        renderDashboardStats();
      } else if (viewId === 'view-inventory') {
        renderInventoryList();
      } else if (viewId === 'view-assets') {
        renderAssetsList();
      } else if (viewId === 'view-asset-checks') {
        renderAssetChecksHistory();
      } else if (viewId === 'view-repairs') {
        renderAssetRepairsList();
      } else if (viewId === 'view-procurements') {
        renderProcurementsList();
      } else if (viewId === 'view-users') {
        renderUsersList();
      } else if (viewId === 'view-profile') {
        setupProfileForm();
      }
      
      // Scroll content to top
      document.getElementById('main-content-scroll').scrollTop = 0;
      
      // Manage officer/admin only views
      manageOfficerAdminButtons();
    }

    // Utility: Hide/Show actions based on role
    function manageOfficerAdminButtons() {
      const restrictItems = document.querySelectorAll('.officer-admin-only');
      const canManage = ['admin', 'officer'].includes(currentUser?.role);
      
      restrictItems.forEach(el => {
        if (canManage) {
          el.classList.remove('hidden');
        } else {
          el.classList.add('hidden');
        }
      });
    }

    // Toggle Admin Panel rising from bottom (Mobile View)
    function toggleMobileAdminPanel(forceState = null) {
      const panel = document.getElementById('mobile-admin-panel');
      const icon = document.getElementById('mobile-admin-icon');
      const isHidden = panel.classList.contains('translate-y-full');
      
      const shouldShow = forceState !== null ? forceState : isHidden;
      
      if (shouldShow) {
        panel.classList.remove('translate-y-full');
        panel.classList.add('translate-y-0');
        icon.setAttribute('data-lucide', 'x');
      } else {
        panel.classList.add('translate-y-full');
        panel.classList.remove('translate-y-0');
        icon.setAttribute('data-lucide', 'menu');
      }
      lucide.createIcons();
    }

    // ==========================================================
    // DATABASE SERVICES & REFRESH LOGIC
    // ==========================================================
    async function refreshAllData() {
      if (!dbClient) return;
      showLoader(true);
      try {
        const [invRes, assetRes, userRes, repairRes, procureRes, reqRes] = await Promise.all([
          dbClient.from('inventory').select('*').order('created_at', { ascending: false }),
          dbClient.from('assets').select('*').order('created_at', { ascending: false }),
          dbClient.from('users').select('*').order('created_at', { ascending: false }),
          dbClient.from('asset_repairs').select('*, assets(code, name, room)').order('created_at', { ascending: false }),
          dbClient.from('procurements').select('*').order('created_at', { ascending: false }),
          dbClient.from('inventory_requests').select('*, inventory(name, unit, stock_remain)').order('created_at', { ascending: false })
        ]);

        if (invRes.error) throw invRes.error;
        if (assetRes.error) throw assetRes.error;
        if (userRes.error) throw userRes.error;
        if (repairRes.error) throw repairRes.error;
        if (procureRes.error) throw procureRes.error;
        if (reqRes.error) throw reqRes.error;

        cacheInventory = invRes.data || [];
        cacheAssets = assetRes.data || [];
        cacheUsers = userRes.data || [];
        cacheRepairs = repairRes.data || [];
        cacheProcurements = procureRes.data || [];
        cacheRequests = reqRes.data || [];

        // Check if any low stock items
        const lowStockCount = cacheInventory.filter(item => item.stock_remain < item.min_threshold).length;
        const alertBtn = document.getElementById('low-stock-alert-btn');
        if (lowStockCount > 0) {
          alertBtn.classList.remove('hidden');
        } else {
          alertBtn.classList.add('hidden');
        }
      } catch (err) {
        console.error('Error fetching database data:', err);
        showToast('การดึงข้อมูลจาก Supabase ล้มเหลว', 'danger');
      } finally {
        showLoader(false);
      }
    }

    // Helper: Show Spinner Loader
    function showLoader(show = true) {
      const loader = document.getElementById('global-loader');
      if (show) {
        loader.classList.remove('hidden');
      } else {
        loader.classList.add('hidden');
      }
    }

    // Helper: Toast Notification
    function showToast(message, type = 'success') {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');
      
      const typeClasses = {
        'success': 'bg-emerald-500 text-white',
        'warning': 'bg-amber-500 text-white',
        'danger': 'bg-red-500 text-white',
        'info': 'bg-indigo-600 text-white'
      };
      
      const iconNames = {
        'success': 'check-circle',
        'warning': 'alert-triangle',
        'danger': 'x-circle',
        'info': 'info'
      };

      toast.className = `p-4 rounded-xl shadow-lg border border-white/10 flex items-center space-x-3 text-sm font-semibold transition-all duration-300 transform translate-x-full ${typeClasses[type]}`;
      toast.innerHTML = `
        <i data-lucide="${iconNames[type]}" class="w-5 h-5 flex-shrink-0"></i>
        <span>${message}</span>
      `;
      
      container.appendChild(toast);
      lucide.createIcons();

      // Slide In
      setTimeout(() => {
        toast.classList.remove('translate-x-full');
      }, 50);

      // Slide Out and Remove
      setTimeout(() => {
        toast.classList.add('opacity-0', 'translate-y-[-10px]');
        setTimeout(() => toast.remove(), 300);
      }, 4000);
    }

    // ==========================================================
    // SUBVIEW 1: DASHBOARD & GRAPH
    // ==========================================================
    async function renderDashboardStats() {
      // Calculate values
      document.getElementById('stat-total-inventory').innerText = cacheInventory.length;
      document.getElementById('stat-total-assets').innerText = cacheAssets.length;
      
      const lowStockCount = cacheInventory.filter(item => item.stock_remain < item.min_threshold).length;
      document.getElementById('stat-low-stock').innerText = lowStockCount;
      
      const totalVal = cacheAssets.reduce((sum, item) => sum + (Number(item.price) || 0), 0);
      document.getElementById('stat-total-asset-value').innerText = totalVal.toLocaleString() + ' ฿';
      
      const damaged = cacheAssets.filter(item => item.status === 'ชำรุด').length;
      document.getElementById('stat-damaged-assets').innerText = damaged;
      
      const pendingReq = cacheRequests.filter(item => item.status === 'pending').length;
      document.getElementById('stat-pending-requests').innerText = pendingReq;
      
      const pendingInspect = cacheAssets.filter(a => a.status === 'ปกติ').length; // Mock or count recent checking
      document.getElementById('stat-pending-inspection').innerText = pendingInspect;

      // Find top requested item
      const requestCounts = {};
      cacheRequests.forEach(r => {
        const invName = r.inventory?.name;
        if (invName) {
          requestCounts[invName] = (requestCounts[invName] || 0) + Number(r.quantity);
        }
      });
      let topItem = '-';
      let maxCount = 0;
      for (const name in requestCounts) {
        if (requestCounts[name] > maxCount) {
          maxCount = requestCounts[name];
          topItem = name;
        }
      }
      document.getElementById('stat-most-requested').innerText = topItem;

      // Render Dashboard Request Approvals
      renderDashboardPendingRequests();

      // Render Charts
      initDashboardCharts();

      // Render AI predictions
      renderAIPredictions();
    }

    function renderDashboardPendingRequests() {
      const container = document.getElementById('dashboard-requests-list');
      const pendingList = cacheRequests.filter(r => r.status === 'pending');
      
      if (pendingList.length === 0) {
        container.innerHTML = `<tr><td colspan="6" class="py-8 text-center text-slate-400">ไม่มีรายการค้างอนุมัติ</td></tr>`;
        return;
      }
      
      container.innerHTML = '';
      
      // Exec and Admin/Officer can approve/reject
      const canApprove = ['admin', 'executive', 'officer'].includes(currentUser?.role);

      pendingList.forEach(r => {
        const row = document.createElement('tr');
        row.className = 'border-b border-slate-100 hover:bg-slate-50 transition';
        row.innerHTML = `
          <td class="py-3 px-4 text-xs font-semibold text-slate-500">${new Date(r.request_date).toLocaleDateString('th-TH')}</td>
          <td class="py-3 px-4 font-bold text-slate-800">${r.borrower}</td>
          <td class="py-3 px-4 text-xs text-slate-500">${r.department}</td>
          <td class="py-3 px-4 text-slate-700">${r.inventory?.name}</td>
          <td class="py-3 px-4 text-xs text-slate-600">${r.quantity} ${r.inventory?.unit}</td>
          <td class="py-3 px-4 flex justify-center space-x-2">
            ${canApprove ? `
              <button onclick="handleRequestApproval('${r.id}', 'approved')" class="px-2 py-1 bg-emerald-500 hover:bg-emerald-600 text-white text-[10px] font-bold rounded-lg transition">อนุมัติ</button>
              <button onclick="handleRequestApproval('${r.id}', 'rejected')" class="px-2 py-1 bg-red-500 hover:bg-red-600 text-white text-[10px] font-bold rounded-lg transition">ปฏิเสธ</button>
            ` : `<span class="text-xs text-amber-500 font-semibold">รอการพิจารณา</span>`}
          </td>
        `;
        container.appendChild(row);
      });
    }

    async function handleRequestApproval(requestId, action) {
      showLoader(true);
      try {
        const requestItem = cacheRequests.find(r => r.id === requestId);
        if (!requestItem) throw new Error("ไม่พบรายการคำขอ");

        const { data, error } = await dbClient
          .from('inventory_requests')
          .update({ 
            status: action,
            approved_by: currentUser.name,
            approved_date: new Date().toISOString()
          })
          .eq('id', requestId)
          .select()
          .single();

        if (error) throw error;

        // If approved, subtract from inventory stock
        if (action === 'approved') {
          const invItem = cacheInventory.find(i => i.id === requestItem.inventory_id);
          if (invItem) {
            const newStockOut = Number(invItem.stock_out) + Number(requestItem.quantity);
            const newStockRemain = Number(invItem.stock_in) - newStockOut;

            if (newStockRemain < 0) {
              throw new Error("สินค้าคงคลังไม่พอให้ตัดยอดสต็อก");
            }

            const { error: stockErr } = await dbClient
              .from('inventory')
              .update({
                stock_out: newStockOut,
                stock_remain: newStockRemain
              })
              .eq('id', requestItem.inventory_id);

            if (stockErr) throw stockErr;
          }
        }

        showToast(action === 'approved' ? 'อนุมัติการเบิกสำเร็จ ยอดสต็อกลดลงอัตโนมัติ' : 'ปฏิเสธคำขอการเบิกแล้ว', 'success');
        await refreshAllData();
        renderDashboardStats();
      } catch (err) {
        showToast(err.message || 'การอนุมัติล้มเหลว', 'danger');
      } finally {
        showLoader(false);
      }
    }

    function initDashboardCharts() {
      const ctx = document.getElementById('monthly-stats-chart').getContext('2d');
      
      // Calculate monthly requests and returns (Mock months if data size is small)
      const months = ['ม.ค.', 'ก.พ.', 'มี.ค.', 'เม.ย.', 'พ.ค.', 'มิ.ย.', 'ก.ค.', 'ส.ค.', 'ก.ย.', 'ต.ค.', 'พ.ย.', 'ธ.ค.'];
      const requestsData = Array(12).fill(0);
      const returnsData = Array(12).fill(0);

      cacheRequests.forEach(req => {
        const date = new Date(req.request_date);
        const mIdx = date.getMonth();
        if (req.status === 'approved') {
          requestsData[mIdx] += Number(req.quantity);
        } else if (req.status === 'returned') {
          returnsData[mIdx] += Number(req.quantity);
        }
      });

      if (monthlyChart) {
        monthlyChart.destroy();
      }

      monthlyChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: months,
          datasets: [
            {
              label: 'ปริมาณการเบิกจ่ายพัสดุ',
              data: requestsData,
              backgroundColor: '#4f46e5',
              borderRadius: 6
            },
            {
              label: 'ปริมาณการคืนพัสดุ',
              data: returnsData,
              backgroundColor: '#10b981',
              borderRadius: 6
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'top',
              labels: {
                font: { family: 'Kanit', size: 11 }
              }
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              grid: { color: '#f1f5f9' },
              ticks: { font: { family: 'Kanit' } }
            },
            x: {
              grid: { display: false },
              ticks: { font: { family: 'Kanit' } }
            }
          }
        }
      });
    }

    // AI Linear Regression & Trend Analysis logic
    function renderAIPredictions() {
      const container = document.getElementById('ai-predictions-container');
      
      if (cacheInventory.length === 0) {
        container.innerHTML = `<p class="text-xs text-slate-400">ไม่มีข้อมูลคำนวณปัญญาประดิษฐ์</p>`;
        return;
      }

      container.innerHTML = '';
      
      // Get the 3 items with lowest stock ratio or highest consumption
      const topItems = cacheInventory.slice(0, 3);

      topItems.forEach(item => {
        // Simple predictive heuristic: Calculate recent demand
        const monthlyDemand = cacheRequests
          .filter(r => r.inventory_id === item.id && r.status === 'approved')
          .reduce((sum, r) => sum + Number(r.quantity), 0);
        
        // Estimate next month demand based on current rate and remaining stock
        const averageMonthlyDemand = Math.max(1, Math.round(monthlyDemand / 3)); // Average for last 3 months
        const remainDays = averageMonthlyDemand > 0 ? Math.round((item.stock_remain / averageMonthlyDemand) * 30) : 999;
        
        let statusColor = 'text-emerald-400';
        let alertMsg = 'สต็อกเพียงพอต่อความต้องการ';
        
        if (item.stock_remain < item.min_threshold) {
          statusColor = 'text-rose-400';
          alertMsg = `ควรสั่งซื้อเพิ่มทันที ${averageMonthlyDemand * 2} ${item.unit}`;
        } else if (remainDays < 15) {
          statusColor = 'text-amber-400';
          alertMsg = `แนะนำสั่งซื้อสำรองใน 10 วันนี้`;
        }

        const div = document.createElement('div');
        div.className = 'bg-slate-800/60 p-3.5 rounded-xl border border-slate-700/50 text-xs flex flex-col justify-between';
        div.innerHTML = `
          <div class="flex justify-between items-start">
            <span class="font-bold text-indigo-300 truncate" style="max-width: 140px;">${item.name}</span>
            <span class="text-[10px] text-slate-400">คงเหลือ ${item.stock_remain} ${item.unit}</span>
          </div>
          <div class="mt-2 text-slate-300 leading-relaxed">
            • คาดการณ์เบิกใช้เดือนถัดไป: <strong>${averageMonthlyDemand} ${item.unit}</strong><br>
            • สต็อกใช้ได้ประมาณ: <strong class="${statusColor}">${remainDays > 365 ? 'เสถียร' : `${remainDays} วัน`}</strong><br>
            • ข้อเสนอแนะ: <span class="font-semibold text-slate-200">${alertMsg}</span>
          </div>
        `;
        container.appendChild(div);
      });
    }

    // ==========================================================
    // SUBVIEW 2: INVENTORY ACTIONS & MANAGEMENT
    // ==========================================================
    function renderInventoryList() {
      const container = document.getElementById('inventory-list');
      const searchVal = document.getElementById('inventory-search').value.toLowerCase();
      
      const filtered = cacheInventory.filter(item => {
        return item.name.toLowerCase().includes(searchVal) || 
               item.code.toLowerCase().includes(searchVal) || 
               item.category.toLowerCase().includes(searchVal);
      });
      
      if (filtered.length === 0) {
        container.innerHTML = `<tr><td colspan="8" class="py-8 text-center text-slate-400">ไม่พบรายการพัสดุใดๆ</td></tr>`;
        return;
      }
      
      container.innerHTML = '';
      
      const isOfficerOrAdmin = ['admin', 'officer'].includes(currentUser?.role);

      filtered.forEach(item => {
        const isLow = item.stock_remain < item.min_threshold;
        const statusBadge = isLow ? 
          `<span class="px-2 py-0.5 bg-rose-50 text-rose-600 text-[10px] font-bold rounded-full border border-rose-100 flex items-center w-max gap-1"><span class="w-1.5 h-1.5 bg-rose-500 rounded-full"></span>ใกล้หมด</span>` : 
          `<span class="px-2 py-0.5 bg-emerald-50 text-emerald-600 text-[10px] font-bold rounded-full border border-emerald-100 flex items-center w-max gap-1"><span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span>ปกติ</span>`;

        const row = document.createElement('tr');
        row.className = 'border-b border-slate-100 hover:bg-slate-50 transition';
        row.innerHTML = `
          <td class="py-3 px-4 font-semibold text-slate-900">${item.code}</td>
          <td class="py-3 px-4">
            <div class="flex flex-col">
              <span class="font-bold text-slate-800">${item.name}</span>
              ${statusBadge}
            </div>
          </td>
          <td class="py-3 px-4 text-xs text-slate-500">${item.category}</td>
          <td class="py-3 px-4 font-bold text-slate-800">${item.stock_remain} <span class="text-xs text-slate-400 font-medium">${item.unit}</span></td>
          <td class="py-3 px-4 text-xs text-slate-500">เข้า ${item.stock_in} / จ่าย ${item.stock_out}</td>
          <td class="py-3 px-4 text-slate-700">${Number(item.price_per_unit).toLocaleString()} ฿</td>
          <td class="py-3 px-4 text-xs text-slate-500">${item.location}</td>
          <td class="py-3 px-4 text-center">
            <div class="flex justify-center space-x-1.5">
              <button onclick="viewInventoryDetails('${item.id}')" class="p-1.5 bg-slate-100 hover:bg-indigo-50 text-slate-600 hover:text-indigo-600 rounded-lg transition" title="รายละเอียด QR Code">
                <i data-lucide="qr-code" class="w-4 h-4"></i>
              </button>
              ${isOfficerOrAdmin ? `
                <button onclick="editInventoryItem('${item.id}')" class="p-1.5 bg-slate-100 hover:bg-emerald-50 text-slate-600 hover:text-emerald-600 rounded-lg transition" title="แก้ไขข้อมูล">
                  <i data-lucide="edit-3" class="w-4 h-4"></i>
                </button>
                <button onclick="deleteInventoryItem('${item.id}')" class="p-1.5 bg-slate-100 hover:bg-rose-50 text-slate-600 hover:text-rose-600 rounded-lg transition" title="ลบพัสดุ">
                  <i data-lucide="trash-2" class="w-4 h-4"></i>
                </button>
              ` : ''}
            </div>
          </td>
        `;
        container.appendChild(row);
      });
      
      lucide.createIcons();
    }

    document.getElementById('inventory-search').addEventListener('input', renderInventoryList);

    // Receive Stock Modal logic
    function openReceiveStockModal() {
      const invSelect = document.getElementById('receive-inventory-id');
      invSelect.innerHTML = cacheInventory.map(item => `<option value="${item.id}">${item.code} | ${item.name} (คงเหลือ: ${item.stock_remain})</option>`).join('');
      
      document.getElementById('receive-quantity').value = 1;
      document.getElementById('receive-price').value = cacheInventory[0]?.price_per_unit || 0;
      document.getElementById('receive-date').value = new Date().toISOString().split('T')[0];
      
      document.getElementById('modal-receive-stock').classList.remove('hidden');
    }

    function closeReceiveStockModal() {
      document.getElementById('modal-receive-stock').classList.add('hidden');
    }

    document.getElementById('form-receive-stock').addEventListener('submit', async (e) => {
      e.preventDefault();
      const type = document.getElementById('receive-log-type').value;
      const invId = document.getElementById('receive-inventory-id').value;
      const quantity = Number(document.getElementById('receive-quantity').value);
      const price = Number(document.getElementById('receive-price').value);
      const seller = document.getElementById('receive-seller').value.trim();
      const po = document.getElementById('receive-po').value.trim();
      const date = document.getElementById('receive-date').value;

      showLoader(true);
      try {
        // Record receipt log
        const { error: logErr } = await dbClient
          .from('inventory_logs')
          .insert({
            inventory_id: invId,
            type,
            po_number: po || null,
            seller: seller || null,
            receive_date: date,
            quantity,
            price,
            created_by: currentUser.name
          });

        if (logErr) throw logErr;

        // Fetch current item to update stock_in and stock_remain
        const currentItem = cacheInventory.find(i => i.id === invId);
        if (!currentItem) throw new Error("ไม่พบรายการพัสดุเพื่ออัปเดตสต็อก");

        const newStockIn = Number(currentItem.stock_in) + quantity;
        const newStockRemain = newStockIn - Number(currentItem.stock_out);

        const { error: invErr } = await dbClient
          .from('inventory')
          .update({
            stock_in: newStockIn,
            stock_remain: newStockRemain
          })
          .eq('id', invId);

        if (invErr) throw invErr;

        showToast('รับพัสดุเข้าคลังเรียบร้อยและอัปเดตสต็อกแล้ว', 'success');
        closeReceiveStockModal();
        await refreshAllData();
        renderInventoryList();
      } catch (err) {
        showToast(err.message || 'บันทึกไม่สำเร็จ', 'danger');
      } finally {
        showLoader(false);
      }
    });

    // Request Borrow Modal logic
    function openRequestBorrowModal() {
      const invSelect = document.getElementById('borrow-inventory-id');
      invSelect.innerHTML = cacheInventory.map(item => `<option value="${item.id}">${item.code} | ${item.name} (คงเหลือ: ${item.stock_remain} ${item.unit})</option>`).join('');
      
      document.getElementById('borrow-quantity').value = 1;
      document.getElementById('borrow-date').value = new Date().toISOString().split('T')[0];
      document.getElementById('borrow-borrower').value = currentUser.name;
      document.getElementById('borrow-department').value = currentUser.department || '';

      document.getElementById('modal-request-borrow').classList.remove('hidden');
    }

    function closeRequestBorrowModal() {
      document.getElementById('modal-request-borrow').classList.add('hidden');
    }

    document.getElementById('form-request-borrow').addEventListener('submit', async (e) => {
      e.preventDefault();
      const invId = document.getElementById('borrow-inventory-id').value;
      const quantity = Number(document.getElementById('borrow-quantity').value);
      const date = document.getElementById('borrow-date').value;
      const borrower = document.getElementById('borrow-borrower').value.trim();
      const dept = document.getElementById('borrow-department').value.trim();

      // Check stock limit before request
      const currentItem = cacheInventory.find(i => i.id === invId);
      if (currentItem && currentItem.stock_remain < quantity) {
        showToast('จำนวนคงเหลือในคลังไม่เพียงพอต่อการเบิก', 'danger');
        return;
      }

      showLoader(true);
      try {
        const { error } = await dbClient
          .from('inventory_requests')
          .insert({
            inventory_id: invId,
            borrower,
            department: dept,
            request_date: date,
            quantity,
            status: 'pending'
          });

        if (error) throw error;

        showToast('ส่งคำขอเบิกพัสดุแล้ว รอผู้รับผิดชอบหรือผู้บริหารอนุมัติ', 'success');
        closeRequestBorrowModal();
        await refreshAllData();
        renderInventoryList();
      } catch (err) {
        showToast(err.message || 'ส่งคำขอไม่สำเร็จ', 'danger');
      } finally {
        showLoader(false);
      }
    });

    // Return Stock Modal logic
    function openReturnStockModal() {
      const select = document.getElementById('return-request-id');
      // Show approved requests for borrower
      const approvedList = cacheRequests.filter(r => r.status === 'approved');
      
      if (approvedList.length === 0) {
        select.innerHTML = `<option value="">ไม่มีรายการอนุมัติเบิกที่สามารถคืนได้</option>`;
      } else {
        select.innerHTML = approvedList.map(r => `
          <option value="${r.id}">${new Date(r.request_date).toLocaleDateString('th-TH')} - ${r.borrower} (${r.inventory?.name}: เบิก ${r.quantity} คืนได้)</option>
        `).join('');
      }
      
      document.getElementById('return-quantity').value = 1;
      document.getElementById('modal-return-stock').classList.remove('hidden');
    }

    function closeReturnStockModal() {
      document.getElementById('modal-return-stock').classList.add('hidden');
    }

    document.getElementById('form-return-stock').addEventListener('submit', async (e) => {
      e.preventDefault();
      const reqId = document.getElementById('return-request-id').value;
      const returnQty = Number(document.getElementById('return-quantity').value);

      if (!reqId) {
        showToast('กรุณาเลือกใบเบิกก่อนทำรายการคืน', 'warning');
        return;
      }

      const requestItem = cacheRequests.find(r => r.id === reqId);
      if (!requestItem) return;

      if (returnQty > requestItem.quantity) {
        showToast('ไม่สามารถคืนเกินจำนวนที่เคยเบิกไปได้', 'danger');
        return;
      }

      showLoader(true);
      try {
        // Update request status to returned
        const { error: reqErr } = await dbClient
          .from('inventory_requests')
          .update({ status: 'returned' })
          .eq('id', reqId);

        if (reqErr) throw reqErr;

        // Return stock: reduce stock_out and increase stock_remain
        const invItem = cacheInventory.find(i => i.id === requestItem.inventory_id);
        if (invItem) {
          const newStockOut = Math.max(0, Number(invItem.stock_out) - returnQty);
          const newStockRemain = Number(invItem.stock_in) - newStockOut;

          const { error: invErr } = await dbClient
            .from('inventory')
            .update({
              stock_out: newStockOut,
              stock_remain: newStockRemain
            })
            .eq('id', requestItem.inventory_id);

          if (invErr) throw invErr;
        }

        showToast('ส่งคืนพัสดุและบวกสต็อกคืนสำเร็จ', 'success');
        closeReturnStockModal();
        await refreshAllData();
        renderInventoryList();
      } catch (err) {
        showToast(err.message || 'ส่งคืนไม่สำเร็จ', 'danger');
      } finally {
        showLoader(false);
      }
    });

    // Mock QR view for single inventory
    function viewInventoryDetails(id) {
      const item = cacheInventory.find(i => i.id === id);
      if (!item) return;

      // Populate mock asset preview modal for printable stickers
      document.getElementById('detail-asset-name').innerText = item.name;
      document.getElementById('detail-asset-code').innerText = item.code;
      document.getElementById('detail-asset-room').innerText = item.location;
      document.getElementById('detail-asset-responsible').innerText = 'เจ้าหน้าที่พัสดุ';
      document.getElementById('detail-asset-brand-model').innerText = 'วัสดุสิ้นเปลือง';
      document.getElementById('detail-asset-price').innerText = item.price_per_unit;
      document.getElementById('detail-asset-fiscal').innerText = '-';
      document.getElementById('detail-asset-status').innerText = 'พร้อมใช้งาน';
      
      document.getElementById('detail-asset-qr-text').innerText = item.code;
      document.getElementById('detail-asset-qr-label').innerText = item.name;

      // Generate QR Code
      const qrCanvas = document.getElementById('detail-asset-qr-canvas');
      QRCode.toCanvas(qrCanvas, item.code, { width: 120, margin: 1 }, function (error) {
        if (error) console.error(error);
      });

      // Generate Barcode
      JsBarcode("#detail-asset-barcode-canvas", item.code, {
        format: "CODE128",
        width: 1.5,
        height: 35,
        displayValue: false
      });

      // Hide repair history for inventory
      document.getElementById('detail-asset-repair-history').innerHTML = `<p class="text-slate-400">วัสดุสิ้นเปลืองไม่มีบันทึกประวัติการซ่อม</p>`;
      document.getElementById('detail-asset-image').style.display = 'none';
      document.getElementById('detail-asset-image').nextElementSibling.style.display = 'flex';

      document.getElementById('modal-view-asset').classList.remove('hidden');
    }

    // Add asset/edit helper
    async function deleteInventoryItem(id) {
      if (!confirm('ยืนยันว่าต้องการลบพัสดุรายการนี้ออกจากระบบหรือไม่?')) return;
      showLoader(true);
      try {
        const { error } = await dbClient.from('inventory').delete().eq('id', id);
        if (error) throw error;
        showToast('ลบรายการพัสดุแล้ว', 'success');
        await refreshAllData();
        renderInventoryList();
      } catch (err) {
        showToast('ไม่สามารถลบได้เนื่องจากมีข้อมูลความสัมพันธ์ในระบบ', 'danger');
      } finally {
        showLoader(false);
      }
    }

    // ==========================================================
    // SUBVIEW 3: ASSET ACTIONS & MANAGEMENT
    // ==========================================================
    function renderAssetsList() {
      const container = document.getElementById('assets-list');
      const searchVal = document.getElementById('asset-search').value.toLowerCase();
      
      const filtered = cacheAssets.filter(item => {
        return item.name.toLowerCase().includes(searchVal) || 
               item.code.toLowerCase().includes(searchVal) || 
               item.room.toLowerCase().includes(searchVal);
      });
      
      if (filtered.length === 0) {
        container.innerHTML = `<tr><td colspan="8" class="py-8 text-center text-slate-400">ไม่พบครุภัณฑ์ในระบบ</td></tr>`;
        return;
      }
      
      container.innerHTML = '';
      
      const isOfficerOrAdmin = ['admin', 'officer'].includes(currentUser?.role);

      filtered.forEach(item => {
        const statusColors = {
          'ปกติ': 'bg-emerald-50 text-emerald-600 border-emerald-100',
          'ชำรุด': 'bg-rose-50 text-rose-600 border-rose-100',
          'ส่งซ่อม': 'bg-amber-50 text-amber-600 border-amber-100',
          'จำหน่าย': 'bg-slate-50 text-slate-600 border-slate-100',
          'สูญหาย': 'bg-red-50 text-red-600 border-red-100'
        };
        const colorClass = statusColors[item.status] || 'bg-slate-50 text-slate-600 border-slate-150';

        const row = document.createElement('tr');
        row.className = 'border-b border-slate-100 hover:bg-slate-50 transition';
        row.innerHTML = `
          <td class="py-3 px-4">
            <div class="w-12 h-12 rounded-lg bg-slate-100 overflow-hidden flex items-center justify-center relative">
              ${item.image_url ? `
                <img src="${item.image_url}" alt="asset" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
              ` : ''}
              <div class="absolute inset-0 flex items-center justify-center text-slate-400 ${item.image_url ? 'hidden' : 'flex'}">
                <i data-lucide="cpu" class="w-5 h-5"></i>
              </div>
            </div>
          </td>
          <td class="py-3 px-4 font-semibold text-slate-900">${item.code}</td>
          <td class="py-3 px-4">
            <div class="flex flex-col">
              <span class="font-bold text-slate-800">${item.name}</span>
              <span class="text-xs text-indigo-600 font-semibold">${Number(item.price).toLocaleString()} ฿</span>
            </div>
          </td>
          <td class="py-3 px-4 text-xs text-slate-650">${item.brand || '-'} / ${item.model || '-'}</td>
          <td class="py-3 px-4 text-xs text-slate-500">${item.room}</td>
          <td class="py-3 px-4 text-xs text-slate-500">${item.responsible_person}</td>
          <td class="py-3 px-4">
            <span class="px-2.5 py-0.5 border text-xs font-bold rounded-full ${colorClass}">${item.status}</span>
          </td>
          <td class="py-3 px-4 text-center">
            <div class="flex justify-center space-x-1.5">
              <button onclick="viewAssetDetails('${item.id}')" class="p-1.5 bg-slate-100 hover:bg-indigo-50 text-slate-600 hover:text-indigo-600 rounded-lg transition" title="พิมพ์สติ๊กเกอร์ QR Code / Barcode">
                <i data-lucide="printer" class="w-4 h-4"></i>
              </button>
              ${isOfficerOrAdmin ? `
                <button onclick="editAssetItem('${item.id}')" class="p-1.5 bg-slate-100 hover:bg-emerald-50 text-slate-600 hover:text-emerald-600 rounded-lg transition" title="แก้ไขข้อมูล">
                  <i data-lucide="edit-3" class="w-4 h-4"></i>
                </button>
                <button onclick="deleteAssetItem('${item.id}')" class="p-1.5 bg-slate-100 hover:bg-rose-50 text-slate-600 hover:text-rose-600 rounded-lg transition" title="ลบข้อมูล">
                  <i data-lucide="trash-2" class="w-4 h-4"></i>
                </button>
              ` : ''}
            </div>
          </td>
        `;
        container.appendChild(row);
      });

      lucide.createIcons();
    }

    document.getElementById('asset-search').addEventListener('input', renderAssetsList);

    // QR/Barcode Viewer & Sticker generator
    function viewAssetDetails(id) {
      const asset = cacheAssets.find(a => a.id === id);
      if (!asset) return;

      document.getElementById('detail-asset-name').innerText = asset.name;
      document.getElementById('detail-asset-code').innerText = asset.code;
      document.getElementById('detail-asset-room').innerText = asset.room;
      document.getElementById('detail-asset-responsible').innerText = asset.responsible_person;
      document.getElementById('detail-asset-brand-model').innerText = `${asset.brand || '-'} / ${asset.model || '-'}`;
      document.getElementById('detail-asset-price').innerText = Number(asset.price).toLocaleString();
      document.getElementById('detail-asset-fiscal').innerText = asset.fiscal_year;
      document.getElementById('detail-asset-status').innerText = asset.status;
      
      document.getElementById('detail-asset-qr-text').innerText = asset.code;
      document.getElementById('detail-asset-qr-label').innerText = asset.name;

      // Handle Image
      const img = document.getElementById('detail-asset-image');
      if (asset.image_url) {
        img.src = asset.image_url;
        img.style.display = 'block';
        img.nextElementSibling.style.display = 'none';
      } else {
        img.style.display = 'none';
        img.nextElementSibling.style.display = 'flex';
      }

      // Generate QR Code
      const qrCanvas = document.getElementById('detail-asset-qr-canvas');
      QRCode.toCanvas(qrCanvas, asset.code, { width: 120, margin: 1 }, function (error) {
        if (error) console.error(error);
      });

      // Generate Barcode
      JsBarcode("#detail-asset-barcode-canvas", asset.code, {
        format: "CODE128",
        width: 1.5,
        height: 35,
        displayValue: false
      });

      // Populate repair history
      const repContainer = document.getElementById('detail-asset-repair-history');
      const repairs = cacheRepairs.filter(r => r.asset_id === asset.id);
      if (repairs.length === 0) {
        repContainer.innerHTML = `<p class="text-slate-400">ไม่มีประวัติการซ่อม</p>`;
      } else {
        repContainer.innerHTML = repairs.map(r => `
          <div class="bg-slate-50 p-2 rounded border border-slate-100">
            <div class="flex justify-between font-bold">
              <span>สถานะ: ${r.status}</span>
              <span>${new Date(r.report_date).toLocaleDateString('th-TH')}</span>
            </div>
            <p class="mt-1">${r.description}</p>
          </div>
        `).join('');
      }

      document.getElementById('modal-view-asset').classList.remove('hidden');
    }

    function closeViewAssetModal() {
      document.getElementById('modal-view-asset').classList.add('hidden');
    }

    // Sticker Printing simulator (Outputs PDF / Window print options)
    function printSticker(size) {
      const assetCode = document.getElementById('detail-asset-code').innerText;
      const assetName = document.getElementById('detail-asset-name').innerText;
      const qrCanvas = document.getElementById('detail-asset-qr-canvas');
      const qrDataUrl = qrCanvas.toDataURL("image/png");

      const { jsPDF } = window.jspdf;
      let doc = new jsPDF({
        orientation: "portrait",
        unit: "cm",
        format: size === 'a4' ? 'a4' : [5, 5]
      });

      if (size === 'a4') {
        // Prints standard A4 grid with multiple labels
        doc.setFont("Helvetica", "bold");
        doc.setFontSize(10);
        
        let x = 1.0;
        let y = 1.0;
        for (let i = 0; i < 24; i++) {
          doc.rect(x, y, 6.0, 4.0);
          doc.addImage(qrDataUrl, 'PNG', x + 0.2, y + 0.2, 2.0, 2.0);
          doc.text(assetName.substring(0, 20), x + 2.4, y + 0.8);
          doc.text(assetCode, x + 2.4, y + 1.4);
          doc.text("PROPERTY OF SCHOOL", x + 2.4, y + 2.0);
          
          x += 6.5;
          if (x > 18) {
            x = 1.0;
            y += 4.5;
          }
          if (y > 25) break;
        }
      } else if (size === '3x5') {
        doc = new jsPDF({
          orientation: "landscape",
          unit: "cm",
          format: [3, 5]
        });
        doc.setFont("Helvetica", "bold");
        doc.setFontSize(6);
        doc.addImage(qrDataUrl, 'PNG', 0.2, 0.2, 1.8, 1.8);
        doc.text(assetName.substring(0, 16), 2.2, 0.6);
        doc.text(assetCode, 2.2, 1.1);
        doc.text("SCHOOL PROPERTY", 2.2, 1.6);
      } else { // 5x5 cm
        doc.setFont("Helvetica", "bold");
        doc.setFontSize(7);
        doc.addImage(qrDataUrl, 'PNG', 1.0, 0.2, 3.0, 3.0);
        doc.text(assetName.substring(0, 24), 0.5, 3.8);
        doc.text(assetCode, 0.5, 4.3);
      }

      window.open(doc.output('bloburl'), '_blank');
      showToast('สร้างไฟล์ PDF สติ๊กเกอร์สำเร็จแล้ว', 'success');
    }

    // Add asset/edit helper
    function openAddAssetModal() {
      document.getElementById('asset-modal-title').innerText = 'เพิ่มครุภัณฑ์ใหม่';
      document.getElementById('asset-edit-id').value = '';
      document.getElementById('form-add-asset').reset();
      document.getElementById('modal-add-asset').classList.remove('hidden');
