    }

    async function editAssetItem(id) {
      const asset = cacheAssets.find(a => a.id === id);
      if (!asset) return;

      document.getElementById('asset-modal-title').innerText = 'แก้ไขข้อมูลครุภัณฑ์';
      document.getElementById('asset-edit-id').value = asset.id;
      document.getElementById('asset-code').value = asset.code;
      document.getElementById('asset-name').value = asset.name;
      document.getElementById('asset-brand').value = asset.brand || '';
      document.getElementById('asset-model').value = asset.model || '';
      document.getElementById('asset-serial').value = asset.serial_number || '';
      document.getElementById('asset-price').value = asset.price;
      document.getElementById('asset-fiscal-year').value = asset.fiscal_year;
      document.getElementById('asset-funding').value = asset.funding_source;
      document.getElementById('asset-room').value = asset.room;
      document.getElementById('asset-responsible').value = asset.responsible_person;
      document.getElementById('asset-status').value = asset.status;

      document.getElementById('modal-add-asset').classList.remove('hidden');
    }

    // Image compression and base64 helper
    async function compressAndUploadImage(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.readAsDataURL(file);
        reader.onload = function (event) {
          const img = new Image();
          img.src = event.target.result;
          img.onload = function () {
            const canvas = document.createElement('canvas');
            const MAX_WIDTH = 800;
            const MAX_HEIGHT = 800;
            let width = img.width;
            let height = img.height;

            if (width > height) {
              if (width > MAX_WIDTH) {
                height *= MAX_WIDTH / width;
                width = MAX_WIDTH;
              }
            } else {
              if (height > MAX_HEIGHT) {
                width *= MAX_HEIGHT / height;
                height = MAX_HEIGHT;
              }
            }
            canvas.width = width;
            canvas.height = height;
            
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0, width, height);

            // Compress to JPEG with 0.6 quality
            canvas.toBlob(async (blob) => {
              try {
                // Generate a unique filename
                const fileExt = 'jpg';
                const fileName = `${Math.random().toString(36).substring(2, 15)}.${fileExt}`;
                const filePath = `uploads/${fileName}`;

                const { data, error } = await dbClient.storage
                  .from('file')
                  .upload(filePath, blob, {
                    contentType: 'image/jpeg'
                  });

                if (error) throw error;

                // Get public URL
                const { data: publicUrlData } = dbClient.storage
                  .from('file')
                  .getPublicUrl(filePath);

                resolve(publicUrlData.publicUrl);
              } catch (err) {
                reject(err);
              }
            }, 'image/jpeg', 0.6);
          };
        };
        reader.onerror = error => reject(error);
      });
    }

    // Form submit for Asset
    document.getElementById('form-add-asset').addEventListener('submit', async (e) => {
      e.preventDefault();
      const id = document.getElementById('asset-edit-id').value;
      let code = document.getElementById('asset-code').value.trim();
      const name = document.getElementById('asset-name').value.trim();
      const brand = document.getElementById('asset-brand').value.trim();
      const model = document.getElementById('asset-model').value.trim();
      const serial = document.getElementById('asset-serial').value.trim();
      const price = Number(document.getElementById('asset-price').value);
      const fiscal = document.getElementById('asset-fiscal-year').value.trim();
      const funding = document.getElementById('asset-funding').value.trim();
      const room = document.getElementById('asset-room').value.trim();
      const responsible = document.getElementById('asset-responsible').value.trim();
      const status = document.getElementById('asset-status').value;
      const imageFile = document.getElementById('asset-image-file').files[0];

      showLoader(true);
      try {
        let imageUrl = null;
        if (imageFile) {
          imageUrl = await compressAndUploadImage(imageFile);
        } else if (id) {
          // Keep existing image if editing and no new file selected
          const existing = cacheAssets.find(a => a.id === id);
          imageUrl = existing?.image_url;
        }

        // Generate Code if blank
        if (!code) {
          const randNum = Math.floor(1000 + Math.random() * 9000);
          code = `ASSET-${fiscal || '2569'}-${randNum}`;
        }

        const payload = {
          code, name, brand, model, serial_number: serial, price, fiscal_year: fiscal, funding_source: funding, room, responsible_person: responsible, status, image_url: imageUrl
        };

        if (id) {
          // Update
          const { error } = await dbClient.from('assets').update(payload).eq('id', id);
          if (error) throw error;
          showToast('แก้ไขข้อมูลครุภัณฑ์เรียบร้อยแล้ว', 'success');
        } else {
          // Insert
          const { error } = await dbClient.from('assets').insert(payload);
          if (error) throw error;
          showToast('เพิ่มครุภัณฑ์ใหม่เข้าสู่ระบบแล้ว', 'success');
        }

        closeAddAssetModal();
        await refreshAllData();
        renderAssetsList();
      } catch (err) {
        showToast(err.message || 'บันทึกไม่สำเร็จ', 'danger');
      } finally {
        showLoader(false);
      }
    });

    async function deleteAssetItem(id) {
      if (!confirm('ยืนยันว่าต้องการลบครุภัณฑ์ชิ้นนี้ออกจากระบบ?')) return;
      showLoader(true);
      try {
        const { error } = await dbClient.from('assets').delete().eq('id', id);
        if (error) throw error;
        showToast('ลบรายการครุภัณฑ์แล้ว', 'success');
        await refreshAllData();
        renderAssetsList();
      } catch (err) {
        showToast('ไม่สามารถลบข้อมูลเนื่องจากติดความสัมพันธ์ในระบบแจ้งซ่อม', 'danger');
      } finally {
        showLoader(false);
      }
    }

    // ==========================================================
    // SUBVIEW 4: ANNUAL INSPECTIONS
    // ==========================================================
    async function renderAssetChecksHistory() {
      const container = document.getElementById('asset-checks-history-list');
      
      showLoader(true);
      try {
        const { data, error } = await dbClient
          .from('asset_checks')
          .select('*, assets(code, name)')
          .order('check_date', { ascending: false });

        if (error) throw error;

        if (!data || data.length === 0) {
          container.innerHTML = `<tr><td colspan="6" class="py-8 text-center text-slate-400">ยังไม่มีข้อมูลการเดินตรวจในระบบ</td></tr>`;
          return;
        }

        container.innerHTML = data.map(item => `
          <tr class="border-b border-slate-100 hover:bg-slate-50 transition">
            <td class="py-3 px-4 text-xs font-semibold text-slate-500">${new Date(item.check_date).toLocaleString('th-TH')}</td>
            <td class="py-3 px-4 font-bold text-slate-900">${item.assets?.code || '-'}</td>
            <td class="py-3 px-4 text-slate-700">${item.assets?.name || '-'}</td>
            <td class="py-3 px-4 text-xs text-slate-500">${item.checker}</td>
            <td class="py-3 px-4">
              <span class="px-2 py-0.5 rounded-full text-xs font-bold ${
                item.status === 'พบครบ' ? 'bg-emerald-50 text-emerald-600 border border-emerald-100' :
                item.status === 'สูญหาย' ? 'bg-red-50 text-red-600 border border-red-100' :
                'bg-amber-50 text-amber-600 border border-amber-100'
              }">${item.status}</span>
            </td>
            <td class="py-3 px-4 text-xs text-slate-500">${item.notes || '-'}</td>
          </tr>
        `).join('');
      } catch (err) {
        showToast('ไม่สามารถดึงข้อมูลประวัติการตรวจได้', 'danger');
      } finally {
        showLoader(false);
      }
    }

    // QR scanner modal trigger
    function openScanQrModal(mode) {
      qrScannerCallbackMode = mode;
      document.getElementById('modal-qr-scanner').classList.remove('hidden');
      
      // Start camera scan
      html5QrScanner = new Html5QrcodeScanner("qr-reader", { 
        fps: 10, 
        qrbox: 250,
        rememberLastUsedCamera: true
      });
      
      html5QrScanner.render(onScanSuccess, onScanError);
    }

    function closeScanQrModal() {
      document.getElementById('modal-qr-scanner').classList.add('hidden');
      if (html5QrScanner) {
        html5QrScanner.clear().catch(e => console.warn(e));
      }
    }

    // QR Callback Router
    async function onScanSuccess(decodedText, decodedResult) {
      closeScanQrModal();
      
      // Decode QR containing Code (e.g. ASSET-2569-0001 or INV001)
      const scannedCode = decodedText.trim();
      showToast(`สแกนพบรหัส: ${scannedCode}`, 'info');

      if (qrScannerCallbackMode === 'view_asset') {
        const item = cacheAssets.find(a => a.code === scannedCode) || cacheInventory.find(i => i.code === scannedCode);
        if (item) {
          if (item.code.startsWith('INV')) {
            viewInventoryDetails(item.id);
          } else {
            viewAssetDetails(item.id);
          }
        } else {
          showToast('ไม่พบรหัสพัสดุ/ครุภัณฑ์นี้ในระบบ', 'warning');
        }
      } else if (qrScannerCallbackMode === 'annual_check') {
        const asset = cacheAssets.find(a => a.code === scannedCode);
        if (asset) {
          openInspectAssetModal(asset.id);
        } else {
          showToast('ไม่พบข้อมูลครุภัณฑ์สำหรับรหัสนี้', 'warning');
        }
      } else if (qrScannerCallbackMode === 'report_repair') {
        const asset = cacheAssets.find(a => a.code === scannedCode);
        if (asset) {
          openReportRepairForm(asset.id);
        } else {
          showToast('ไม่พบครุภัณฑ์ในระบบเพื่อทำการแจ้งซ่อม', 'warning');
        }
      }
    }

    function onScanError(err) {
      // Quiet scanner failures (mostly polling errors)
    }

    // Inspect Asset Modal Form
    function openInspectAssetModal(assetId) {
      const asset = cacheAssets.find(a => a.id === assetId);
      if (!asset) return;

      document.getElementById('inspect-asset-name').innerText = asset.name;
      document.getElementById('inspect-asset-code').innerText = asset.code;
      document.getElementById('inspect-notes').value = '';
      
      // Save temp ID to data-attribute
      document.getElementById('modal-inspect-asset-action').setAttribute('data-current-asset-id', asset.id);
      document.getElementById('modal-inspect-asset-action').classList.remove('hidden');
    }

    function closeInspectAssetModal() {
      document.getElementById('modal-inspect-asset-action').classList.add('hidden');
    }

    async function submitAssetInspection(status) {
      const assetId = document.getElementById('modal-inspect-asset-action').getAttribute('data-current-asset-id');
      const notes = document.getElementById('inspect-notes').value.trim();

      showLoader(true);
      try {
        // Record inspection
        const { error: checkErr } = await dbClient
          .from('asset_checks')
          .insert({
            asset_id: assetId,
            checker: currentUser.name,
            status,
            notes: notes || null
          });

        if (checkErr) throw checkErr;

        // Map status to Asset status schema and update
        let newAssetStatus = 'ปกติ';
        if (status === 'สูญหาย') newAssetStatus = 'สูญหาย';
        else if (status === 'ชำรุด') newAssetStatus = 'ชำรุด';

        const { error: assetErr } = await dbClient
          .from('assets')
          .update({ status: newAssetStatus })
          .eq('id', assetId);

        if (assetErr) throw assetErr;

        showToast('บันทึกการตรวจสอบครุภัณฑ์และอัปเดตสถานะสำเร็จ', 'success');
        closeInspectAssetModal();
        await refreshAllData();
        renderAssetChecksHistory();
      } catch (err) {
        showToast(err.message || 'บันทึกไม่สำเร็จ', 'danger');
      } finally {
        showLoader(false);
      }
    }

    // ==========================================================
    // SUBVIEW 5: REPAIR REQUESTS & STATUSES
    // ==========================================================
    function renderAssetRepairsList() {
      const container = document.getElementById('asset-repairs-list');
      
      if (cacheRepairs.length === 0) {
        container.innerHTML = `<tr><td colspan="7" class="py-8 text-center text-slate-400">ไม่มีรายการแจ้งซ่อมบำรุง</td></tr>`;
        return;
      }

      container.innerHTML = '';
      const isOfficerOrAdmin = ['admin', 'officer'].includes(currentUser?.role);

      cacheRepairs.forEach(rep => {
        const row = document.createElement('tr');
        row.className = 'border-b border-slate-100 hover:bg-slate-50 transition';
        row.innerHTML = `
          <td class="py-3 px-4">
            <div class="w-12 h-12 rounded-lg bg-slate-100 overflow-hidden flex items-center justify-center relative">
              ${rep.image_url ? `
                <img src="${rep.image_url}" alt="repair" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
              ` : ''}
              <div class="absolute inset-0 flex items-center justify-center text-slate-400 ${rep.image_url ? 'hidden' : 'flex'}">
                <i data-lucide="image-off" class="w-5 h-5"></i>
              </div>
            </div>
          </td>
          <td class="py-3 px-4 text-xs text-slate-500">${new Date(rep.report_date).toLocaleDateString('th-TH')}</td>
          <td class="py-3 px-4">
            <div class="flex flex-col">
              <span class="font-bold text-slate-800">${rep.assets?.name || 'ไม่ทราบครุภัณฑ์'}</span>
              <span class="text-xs text-indigo-600 font-semibold">${rep.assets?.code || '-'}</span>
              <span class="text-[10px] text-slate-400">ห้อง: ${rep.assets?.room || '-'}</span>
            </div>
          </td>
          <td class="py-3 px-4 text-slate-700 font-medium">${rep.description}</td>
          <td class="py-3 px-4 text-xs text-slate-500">${rep.reporter}</td>
          <td class="py-3 px-4">
            <span class="px-2 py-0.5 rounded-full text-xs font-bold ${
              rep.status === 'แจ้งแล้ว' ? 'bg-indigo-50 text-indigo-600 border border-indigo-100' :
              rep.status === 'กำลังดำเนินการ' ? 'bg-amber-50 text-amber-600 border border-amber-100' :
              rep.status === 'ซ่อมเสร็จ' ? 'bg-emerald-50 text-emerald-600 border border-emerald-100' :
              'bg-slate-50 text-slate-600 border border-slate-100'
            }">${rep.status}</span>
          </td>
          <td class="py-3 px-4 text-center">
            ${isOfficerOrAdmin ? `
              <select onchange="updateRepairStatus('${rep.id}', this.value)" class="px-2 py-1 text-xs border border-slate-200 rounded-lg focus:outline-none">
                <option value="แจ้งแล้ว" ${rep.status === 'แจ้งแล้ว' ? 'selected' : ''}>แจ้งแล้ว</option>
                <option value="กำลังดำเนินการ" ${rep.status === 'กำลังดำเนินการ' ? 'selected' : ''}>กำลังดำเนินการ</option>
                <option value="ซ่อมเสร็จ" ${rep.status === 'ซ่อมเสร็จ' ? 'selected' : ''}>ซ่อมเสร็จ</option>
                <option value="จำหน่าย" ${rep.status === 'จำหน่าย' ? 'selected' : ''}>จำหน่าย/ตัดชำรุด</option>
              </select>
            ` : `<span class="text-xs text-slate-400">สำหรับเจ้าหน้าที่</span>`}
          </td>
        `;
        container.appendChild(row);
      });

      lucide.createIcons();
    }

    // Update Repair Status
    async function updateRepairStatus(repairId, newStatus) {
      showLoader(true);
      try {
        const payload = { status: newStatus };
        if (newStatus === 'ซ่อมเสร็จ') {
          payload.resolved_date = new Date().toISOString();
        }

        const { error: repErr } = await dbClient
          .from('asset_repairs')
          .update(payload)
          .eq('id', repairId);

        if (repErr) throw repErr;

        // If status changed to Repair Completed or Disposed, update the Asset table too
        const repairItem = cacheRepairs.find(r => r.id === repairId);
        if (repairItem) {
          let assetStatus = 'ปกติ';
          if (newStatus === 'กำลังดำเนินการ') assetStatus = 'ส่งซ่อม';
          else if (newStatus === 'จำหน่าย') assetStatus = 'จำหน่าย';

          const { error: assetErr } = await dbClient
            .from('assets')
            .update({ status: assetStatus })
            .eq('id', repairItem.asset_id);

          if (assetErr) throw assetErr;
        }

        showToast('อัปเดตสถานะการส่งซ่อมบำรุงแล้ว', 'success');
        await refreshAllData();
        renderAssetRepairsList();
      } catch (err) {
        showToast(err.message || 'บันทึกไม่สำเร็จ', 'danger');
      } finally {
        showLoader(false);
      }
    }

    // Open Report Repair Form (triggered after scanning)
    function openReportRepairForm(assetId) {
      const asset = cacheAssets.find(a => a.id === assetId);
      if (!asset) return;

      document.getElementById('repair-asset-id').value = asset.id;
      document.getElementById('repair-asset-name-label').innerText = asset.name;
      document.getElementById('repair-asset-code-label').innerText = asset.code;
      document.getElementById('repair-description').value = '';
      document.getElementById('repair-reporter').value = currentUser.name;

      document.getElementById('modal-report-repair-form').classList.remove('hidden');
    }

    function closeReportRepairModal() {
      document.getElementById('modal-report-repair-form').classList.add('hidden');
    }

    document.getElementById('form-report-repair').addEventListener('submit', async (e) => {
      e.preventDefault();
      const assetId = document.getElementById('repair-asset-id').value;
      const desc = document.getElementById('repair-description').value.trim();
      const reporter = document.getElementById('repair-reporter').value.trim();
      const imageFile = document.getElementById('repair-image-file').files[0];

      showLoader(true);
      try {
        let imageUrl = null;
        if (imageFile) {
          imageUrl = await compressAndUploadImage(imageFile);
        }

        const { error: repErr } = await dbClient
          .from('asset_repairs')
          .insert({
            asset_id: assetId,
            reporter,
            description: desc,
            image_url: imageUrl,
            status: 'แจ้งแล้ว'
          });

        if (repErr) throw repErr;

        // Auto change Asset Status to Damaged
        const { error: assetErr } = await dbClient
          .from('assets')
          .update({ status: 'ชำรุด' })
          .eq('id', assetId);

        if (assetErr) throw assetErr;

        showToast('แจ้งซ่อมข้อมูลขัดข้องเข้าสู่ระบบแล้ว', 'success');
        closeReportRepairModal();
        await refreshAllData();
        renderAssetRepairsList();
      } catch (err) {
        showToast(err.message || 'แจ้งซ่อมล้มเหลว', 'danger');
      } finally {
        showLoader(false);
      }
    });

    // ==========================================================
    // SUBVIEW 6: PROCUREMENT SYSTEM
    // ==========================================================
    function renderProcurementsList() {
      const container = document.getElementById('procurements-list');
      
      if (cacheProcurements.length === 0) {
        container.innerHTML = `<tr><td colspan="7" class="py-8 text-center text-slate-400">ยังไม่มีประวัติโครงการจัดซื้อ</td></tr>`;
        return;
      }

      container.innerHTML = '';
      const isExecutiveOrAdmin = ['admin', 'executive'].includes(currentUser?.role);

      cacheProcurements.forEach(item => {
        // Items string display
        const itemsList = item.items ? item.items.map(p => `• ${p.name} (${p.quantity} x ${p.price_per_unit} ฿)`).join('<br>') : '-';
        
        const row = document.createElement('tr');
        row.className = 'border-b border-slate-100 hover:bg-slate-50 transition text-xs';
        row.innerHTML = `
          <td class="py-3 px-4 font-bold text-slate-800 text-sm">${item.project_name}</td>
          <td class="py-3 px-4 text-slate-600 font-semibold">${item.fiscal_year}</td>
          <td class="py-3 px-4 text-slate-600">${item.seller || '-'}</td>
          <td class="py-3 px-4 space-y-1">
            ${item.quotation_url ? `<a href="${item.quotation_url}" target="_blank" class="block text-indigo-600 hover:underline">ใบเสนอราคา</a>` : ''}
            ${item.po_url ? `<a href="${item.po_url}" target="_blank" class="block text-indigo-600 hover:underline">ใบสั่งซื้อ PO</a>` : ''}
            ${item.receive_url ? `<a href="${item.receive_url}" target="_blank" class="block text-indigo-600 hover:underline">ใบตรวจรับ</a>` : ''}
          </td>
          <td class="py-3 px-4 text-slate-650 leading-relaxed">${itemsList}</td>
          <td class="py-3 px-4">
            <span class="px-2 py-0.5 rounded-full text-[10px] font-bold ${
              item.status === 'approved' ? 'bg-emerald-50 text-emerald-600 border border-emerald-100' :
              item.status === 'rejected' ? 'bg-red-50 text-red-600 border border-red-100' :
              'bg-amber-50 text-amber-600 border border-amber-100'
            }">${item.status === 'approved' ? 'ตรวจรับเข้าคลังแล้ว' : item.status === 'rejected' ? 'ยกเลิกโครงการ' : 'รอการตรวจรับ'}</span>
          </td>
          <td class="py-3 px-4 text-center">
            ${item.status === 'pending' && isExecutiveOrAdmin ? `
              <div class="flex justify-center space-x-1.5">
                <button onclick="approveProcurement('${item.id}', 'approved')" class="px-2 py-1 bg-emerald-500 hover:bg-emerald-600 text-white text-[10px] font-bold rounded-lg transition">ตรวจรับ</button>
                <button onclick="approveProcurement('${item.id}', 'rejected')" class="px-2 py-1 bg-red-500 hover:bg-red-600 text-white text-[10px] font-bold rounded-lg transition">ยกเลิก</button>
              </div>
            ` : `<span class="text-slate-400">สิ้นสุดรายการ</span>`}
          </td>
        `;
        container.appendChild(row);
      });
    }

    // Approve procurement to automatically import items into inventory stock
    async function approveProcurement(procId, status) {
      showLoader(true);
      try {
        const procurement = cacheProcurements.find(p => p.id === procId);
        if (!procurement) throw new Error("ไม่พบข้อมูลโครงการ");

        // Update procurement status
        const { error: procErr } = await dbClient
          .from('procurements')
          .update({ status })
          .eq('id', procId);

        if (procErr) throw procErr;

        // Auto import stock when approved
        if (status === 'approved' && procurement.items) {
          for (const rawItem of procurement.items) {
            // Find existing matching name, else insert new item
            const existItem = cacheInventory.find(i => i.name.toLowerCase() === rawItem.name.toLowerCase());
            
            if (existItem) {
              const newStockIn = Number(existItem.stock_in) + Number(rawItem.quantity);
              const newStockRemain = newStockIn - Number(existItem.stock_out);

              const { error: updateErr } = await dbClient
                .from('inventory')
                .update({
                  stock_in: newStockIn,
                  stock_remain: newStockRemain,
                  price_per_unit: rawItem.price_per_unit
                })
                .eq('id', existItem.id);

              if (updateErr) throw updateErr;

              // Insert Log
              await dbClient.from('inventory_logs').insert({
                inventory_id: existItem.id,
                type: 'purchase',
                seller: procurement.seller,
                receive_date: new Date().toISOString().split('T')[0],
                quantity: rawItem.quantity,
                price: rawItem.price_per_unit,
                created_by: currentUser.name
              });
            } else {
              // Generate code
              const randNum = Math.floor(100 + Math.random() * 900);
              const newCode = `INV${randNum}`;

              const { data: inserted, error: insertErr } = await dbClient
                .from('inventory')
                .insert({
                  code: newCode,
                  name: rawItem.name,
                  category: rawItem.category || 'อื่นๆ',
                  unit: rawItem.unit || 'ชิ้น',
                  price_per_unit: rawItem.price_per_unit,
                  stock_in: rawItem.quantity,
                  stock_out: 0,
                  stock_remain: rawItem.quantity,
                  min_threshold: 5,
                  location: rawItem.location || 'ห้องพัสดุ'
                })
                .select()
                .single();

              if (insertErr) throw insertErr;

              // Insert Log
              await dbClient.from('inventory_logs').insert({
                inventory_id: inserted.id,
                type: 'purchase',
                seller: procurement.seller,
                receive_date: new Date().toISOString().split('T')[0],
                quantity: rawItem.quantity,
                price: rawItem.price_per_unit,
                created_by: currentUser.name
              });
            }
          }
        }

        showToast(status === 'approved' ? 'ตรวจรับโครงการและเพิ่มยอดคงคลังอัตโนมัติแล้ว' : 'ยกเลิกโครงการแล้ว', 'success');
        await refreshAllData();
        renderProcurementsList();
      } catch (err) {
        showToast(err.message || 'เกิดข้อผิดพลาด', 'danger');
      } finally {
        showLoader(false);
      }
    }

    // Add row to procurement items form
    function addProcureItemRow() {
      const container = document.getElementById('procure-items-list-container');
      const rowId = 'p-row-' + Math.random().toString(36).substring(2, 9);
      
      const div = document.createElement('div');
      div.id = rowId;
      div.className = 'grid grid-cols-5 gap-2 items-center';
      div.innerHTML = `
        <input type="text" placeholder="ชื่อพัสดุ" required class="col-span-2 px-3 py-1 text-xs border border-slate-200 rounded-lg focus:outline-none p-item-name">
        <input type="number" placeholder="ราคาต่อหน่วย" required min="0" class="px-3 py-1 text-xs border border-slate-200 rounded-lg focus:outline-none p-item-price">
        <input type="number" placeholder="จำนวน" required min="1" class="px-3 py-1 text-xs border border-slate-200 rounded-lg focus:outline-none p-item-qty">
        <button type="button" onclick="document.getElementById('${rowId}').remove()" class="p-1 text-red-500 hover:bg-red-50 rounded-lg text-center flex items-center justify-center">
          <i data-lucide="trash" class="w-4 h-4"></i>
        </button>
      `;
      container.appendChild(div);
      lucide.createIcons();
    }

    function openAddProcurementModal() {
      document.getElementById('form-add-procurement').reset();
      document.getElementById('procure-items-list-container').innerHTML = '';
      addProcureItemRow(); // Add default row
      document.getElementById('modal-add-procurement').classList.remove('hidden');
    }

    function closeAddProcurementModal() {
      document.getElementById('modal-add-procurement').classList.add('hidden');
    }

    document.getElementById('form-add-procurement').addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = document.getElementById('procure-name').value.trim();
      const fiscal = document.getElementById('procure-fiscal').value.trim();
      const seller = document.getElementById('procure-seller').value.trim();
      const fileQuotation = document.getElementById('procure-file-quotation').files[0];
      const filePo = document.getElementById('procure-file-po').files[0];
      const fileReceive = document.getElementById('procure-file-receive').files[0];

      // Parse items
      const items = [];
      const rows = document.getElementById('procure-items-list-container').children;
      for (const row of rows) {
        const itemName = row.querySelector('.p-item-name').value.trim();
        const price = Number(row.querySelector('.p-item-price').value);
        const qty = Number(row.querySelector('.p-item-qty').value);
        if (itemName) {
          items.push({ name: itemName, price_per_unit: price, quantity: qty, category: 'เครื่องเขียน', unit: 'ชิ้น', location: 'ห้องพัสดุ' });
        }
      }

      showLoader(true);
      try {
        let qUrl = null, poUrl = null, rUrl = null;
        if (fileQuotation) qUrl = await compressAndUploadImage(fileQuotation);
        if (filePo) poUrl = await compressAndUploadImage(filePo);
        if (fileReceive) rUrl = await compressAndUploadImage(fileReceive);

        const { error } = await dbClient
          .from('procurements')
          .insert({
            project_name: name,
            fiscal_year: fiscal,
            seller,
            quotation_url: qUrl,
            po_url: poUrl,
            receive_url: rUrl,
            status: 'pending',
            items
          });

        if (error) throw error;

        showToast('สร้างใบโครงการจัดซื้อจัดจ้างสำเร็จแล้ว', 'success');
        closeAddProcurementModal();
        await refreshAllData();
        renderProcurementsList();
      } catch (err) {
        showToast(err.message || 'บันทึกไม่สำเร็จ', 'danger');
      } finally {
        showLoader(false);
      }
    });


    // ==========================================================
    // SUBVIEW 7: REPORTS SYSTEM
    // ==========================================================
    let currentReportKey = '';

    async function viewReportDetail(reportKey) {
      currentReportKey = reportKey;
      const titleEl = document.getElementById('report-title');
      const descEl = document.getElementById('report-desc');
      const header = document.getElementById('report-result-header');
      const body = document.getElementById('report-result-body');
      
      document.getElementById('report-details-panel').classList.remove('hidden');

      if (reportKey === 'low_stock') {
        titleEl.innerText = 'รายงานพัสดุสิ้นเปลืองใกล้หมดคลัง';
        descEl.innerText = 'แสดงรายการพัสดุที่มีจำนวนยอดคงเหลือต่ำกว่าจุดสั่งซื้อต่ำสุดที่กำหนดไว้';
        
        header.innerHTML = `
          <tr>
            <th class="py-3 px-4">รหัสพัสดุ</th>
            <th class="py-3 px-4">ชื่อพัสดุ</th>
            <th class="py-3 px-4">คงเหลือ</th>
            <th class="py-3 px-4">จุดสั่งซื้อต่ำสุด</th>
            <th class="py-3 px-4">สถานที่จัดเก็บ</th>
          </tr>
        `;
        
        const lowItems = cacheInventory.filter(item => item.stock_remain < item.min_threshold);
        if (lowItems.length === 0) {
          body.innerHTML = `<tr><td colspan="5" class="py-8 text-center text-slate-400">ไม่มีพัสดุใกล้หมดคลัง สต็อกปกติดีทุกรายการ</td></tr>`;
        } else {
          body.innerHTML = lowItems.map(item => `
            <tr class="hover:bg-slate-50 transition border-b border-slate-100">
              <td class="py-3 px-4 font-semibold text-slate-900">${item.code}</td>
              <td class="py-3 px-4 font-bold text-slate-800">${item.name}</td>
              <td class="py-3 px-4 text-red-600 font-bold">${item.stock_remain} ${item.unit}</td>
              <td class="py-3 px-4 font-semibold text-slate-500">${item.min_threshold}</td>
              <td class="py-3 px-4 text-xs text-slate-500">${item.location}</td>
            </tr>
          `).join('');
        }
      } else if (reportKey === 'borrow_logs') {
        titleEl.innerText = 'รายงานประวัติการเบิกจ่ายพัสดุสะสม';
        descEl.innerText = 'แสดงข้อมูลประวัติสะสมทั้งหมดที่มีการขอเบิกวัสดุสิ้นเปลืองพร้อมสถานะการคืน';

        header.innerHTML = `
          <tr>
            <th class="py-3 px-4">วันที่เบิก</th>
            <th class="py-3 px-4">ชื่อพัสดุ</th>
            <th class="py-3 px-4">ผู้ขอเบิก</th>
            <th class="py-3 px-4">ฝ่าย/กลุ่มสาระ</th>
            <th class="py-3 px-4">จำนวนเบิก</th>
            <th class="py-3 px-4">สถานะการทำรายการ</th>
          </tr>
        `;

        if (cacheRequests.length === 0) {
          body.innerHTML = `<tr><td colspan="6" class="py-8 text-center text-slate-400">ไม่มีประวัติการเบิกจ่ายใดๆ</td></tr>`;
        } else {
          body.innerHTML = cacheRequests.map(r => `
            <tr class="hover:bg-slate-50 transition border-b border-slate-100 text-xs">
              <td class="py-3 px-4 font-semibold text-slate-500">${new Date(r.request_date).toLocaleDateString('th-TH')}</td>
              <td class="py-3 px-4 font-bold text-slate-800 text-sm">${r.inventory?.name || '-'}</td>
              <td class="py-3 px-4 font-semibold text-slate-700">${r.borrower}</td>
              <td class="py-3 px-4 text-slate-500">${r.department}</td>
              <td class="py-3 px-4 text-slate-700 font-bold">${r.quantity} ${r.inventory?.unit || ''}</td>
              <td class="py-3 px-4">
                <span class="px-2 py-0.5 rounded-full font-bold ${
                  r.status === 'approved' ? 'bg-emerald-50 text-emerald-600 border border-emerald-100' :
                  r.status === 'returned' ? 'bg-indigo-50 text-indigo-600 border border-indigo-100' :
                  r.status === 'rejected' ? 'bg-red-50 text-red-600 border border-red-100' :
                  'bg-amber-50 text-amber-600 border border-amber-100'
                }">${r.status}</span>
              </td>
            </tr>
          `).join('');
        }
      } else if (reportKey === 'assets_group') {
        titleEl.innerText = 'รายงานมูลค่าทรัพย์สินตามปีงบประมาณและห้อง';
        descEl.innerText = 'สรุปรายชื่อและมูลค่ารวมทรัพย์สินทั้งหมดที่ติดตั้งในสถานศึกษา';

        header.innerHTML = `
          <tr>
            <th class="py-3 px-4">เลขครุภัณฑ์</th>
            <th class="py-3 px-4">ชื่อครุภัณฑ์</th>
            <th class="py-3 px-4">ห้อง/สถานที่</th>
            <th class="py-3 px-4">ผู้ดูแล</th>
            <th class="py-3 px-4">ปีงบประมาณ</th>
            <th class="py-3 px-4">มูลค่าราคาประเมิน</th>
          </tr>
        `;

        if (cacheAssets.length === 0) {
          body.innerHTML = `<tr><td colspan="6" class="py-8 text-center text-slate-400">ไม่มีข้อมูลครุภัณฑ์</td></tr>`;
        } else {
          let rowsHtml = cacheAssets.map(a => `
            <tr class="hover:bg-slate-50 transition border-b border-slate-100 text-xs">
              <td class="py-3 px-4 font-semibold text-slate-500">${a.code}</td>
              <td class="py-3 px-4 font-bold text-slate-800 text-sm">${a.name}</td>
              <td class="py-3 px-4 text-slate-650">${a.room}</td>
              <td class="py-3 px-4 text-slate-500">${a.responsible_person}</td>
              <td class="py-3 px-4 text-slate-500 font-bold">${a.fiscal_year}</td>
              <td class="py-3 px-4 text-slate-800 font-bold">${Number(a.price).toLocaleString()} ฿</td>
            </tr>
          `).join('');

          const totalVal = cacheAssets.reduce((sum, item) => sum + (Number(item.price) || 0), 0);
          rowsHtml += `
            <tr class="bg-slate-50 font-bold text-slate-900 border-t-2 border-slate-200">
              <td colspan="5" class="py-4 px-4 text-right text-sm">มูลค่าครุภัณฑ์สะสมรวมทั้งหมด:</td>
              <td class="py-4 px-4 text-indigo-600 text-sm">${totalVal.toLocaleString()} ฿</td>
            </tr>
          `;
          body.innerHTML = rowsHtml;
        }
      }
      
      // Bind exports dynamically
      document.getElementById('btn-export-pdf').onclick = () => exportReport(reportKey, 'pdf');
      document.getElementById('btn-export-excel').onclick = () => exportReport(reportKey, 'excel');
    }

    // Export to PDF / Excel utilizing standard libraries
    function exportReport(reportKey, type) {
      if (type === 'excel') {
        const table = document.getElementById('report-result-table');
        const wb = XLSX.utils.table_to_book(table, { sheet: "Sheet JS" });
        XLSX.writeFile(wb, `Report-${reportKey}-${new Date().toISOString().split('T')[0]}.xlsx`);
        showToast('ดาวน์โหลดเอกสาร Excel เรียบร้อยแล้ว', 'success');
      } else {
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF('p', 'pt', 'a4');
        
        // Simulating auto table PDF creation
        doc.setFont("Helvetica", "bold");
        doc.text(document.getElementById('report-title').innerText, 40, 40);
        doc.setFontSize(10);
        doc.text(document.getElementById('report-desc').innerText, 40, 60);

        doc.autoTable({
          html: '#report-result-table',
          startY: 80,
          styles: { font: 'Helvetica', fontSize: 8 },
          theme: 'grid'
        });

        doc.save(`Report-${reportKey}-${new Date().toISOString().split('T')[0]}.pdf`);
        showToast('ดาวน์โหลดเอกสาร PDF เรียบร้อยแล้ว', 'success');
      }
    }

    // ==========================================================
    // SUBVIEW 8: USER MANAGEMENT
    // ==========================================================
    function renderUsersList() {
      const container = document.getElementById('users-list');
      container.innerHTML = '';

      cacheUsers.forEach(user => {
        const row = document.createElement('tr');
        row.className = 'border-b border-slate-100 hover:bg-slate-50 transition text-sm';
        row.innerHTML = `
          <td class="py-3 px-4 font-bold text-slate-800">${user.name}</td>
          <td class="py-3 px-4 text-slate-650">${user.username}</td>
          <td class="py-3 px-4 font-semibold text-indigo-600">${getRoleLabel(user.role)}</td>
          <td class="py-3 px-4 text-xs text-slate-500">${user.department}</td>
          <td class="py-3 px-4 text-center">
            <div class="flex justify-center space-x-1.5">
              <button onclick="editUserItem('${user.id}')" class="p-1.5 bg-slate-100 hover:bg-indigo-50 text-slate-600 hover:text-indigo-600 rounded-lg transition" title="แก้ไขข้อมูล"><i data-lucide="edit" class="w-4 h-4"></i></button>
              <button onclick="deleteUserItem('${user.id}')" class="p-1.5 bg-slate-100 hover:bg-rose-50 text-slate-600 hover:text-rose-600 rounded-lg transition" title="ลบข้อมูลผู้ใช้"><i data-lucide="trash" class="w-4 h-4"></i></button>
            </div>
          </td>
        `;
        container.appendChild(row);
      });
      lucide.createIcons();
    }

    function openAddUserModal() {
      document.getElementById('user-modal-title').innerText = 'เพิ่มผู้ใช้ใหม่ในระบบ';
      document.getElementById('user-edit-id').value = '';
      document.getElementById('form-add-user').reset();
      document.getElementById('user-username').disabled = false;
      document.getElementById('modal-add-user').classList.remove('hidden');
    }

    function closeAddUserModal() {
      document.getElementById('modal-add-user').classList.add('hidden');
    }

    async function editUserItem(id) {
      const u = cacheUsers.find(x => x.id === id);
      if (!u) return;

      document.getElementById('user-modal-title').innerText = 'แก้ไขข้อมูลสิทธิ์การใช้งาน';
      document.getElementById('user-edit-id').value = u.id;
      document.getElementById('user-full-name').value = u.name;
      document.getElementById('user-department').value = u.department;
      document.getElementById('user-username').value = u.username;
      document.getElementById('user-username').disabled = true; // Cannot edit username
      document.getElementById('user-password').value = u.password;
      document.getElementById('user-role').value = u.role;

      document.getElementById('modal-add-user').classList.remove('hidden');
    }

    document.getElementById('form-add-user').addEventListener('submit', async (e) => {
      e.preventDefault();
      const id = document.getElementById('user-edit-id').value;
      const name = document.getElementById('user-full-name').value.trim();
      const dept = document.getElementById('user-department').value.trim();
      const username = document.getElementById('user-username').value.trim();
      const password = document.getElementById('user-password').value.trim();
      const role = document.getElementById('user-role').value;

      showLoader(true);
      try {
        const payload = { name, department: dept, password, role };
        
        if (id) {
          const { error } = await dbClient.from('users').update(payload).eq('id', id);
          if (error) throw error;
          showToast('อัปเดตข้อมูลผู้ใช้งานและสิทธิ์เข้าใช้สำเร็จ', 'success');
        } else {
          // Insert
          const { error } = await dbClient.from('users').insert({ ...payload, username });
          if (error) throw error;
          showToast('เพิ่มข้อมูลผู้ใช้ใหม่สำเร็จ', 'success');
        }

        closeAddUserModal();
        await refreshAllData();
        renderUsersList();
      } catch (err) {
        showToast(err.message || 'บันทึกข้อมูลไม่สำเร็จ', 'danger');
      } finally {
        showLoader(false);
      }
    });

    async function deleteUserItem(id) {
      if (id === currentUser.id) {
        showToast('ไม่สามารถลบบัญชีผู้ใช้ของคุณเองได้', 'warning');
        return;
      }
      if (!confirm('ยืนยันลบบัญชีผู้ใช้นี้ออกจากระบบ?')) return;
      
      showLoader(true);
      try {
        const { error } = await dbClient.from('users').delete().eq('id', id);
        if (error) throw error;
        showToast('ลบผู้ใช้งานแล้ว', 'success');
        await refreshAllData();
        renderUsersList();
      } catch (err) {
        showToast('ไม่สามารถลบผู้ใช้งานได้', 'danger');
      } finally {
        showLoader(false);
      }
    }

    // ==========================================================
    // SUBVIEW 9: PROFILE MANAGEMENT
    // ==========================================================
    function setupProfileForm() {
      document.getElementById('profile-full-name').innerText = currentUser.name;
      document.getElementById('profile-role-badge').innerText = getRoleLabel(currentUser.role);
      document.getElementById('profile-avatar').innerText = currentUser.name.charAt(0).toUpperCase();

      document.getElementById('profile-name').value = currentUser.name;
      document.getElementById('profile-dept').value = currentUser.department;
      document.getElementById('profile-password').value = '';
    }

    document.getElementById('profile-edit-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = document.getElementById('profile-name').value.trim();
      const dept = document.getElementById('profile-dept').value.trim();
      const newPass = document.getElementById('profile-password').value.trim();

      const payload = { name, department: dept };
      if (newPass) {
        payload.password = newPass;
      }

      showLoader(true);
      try {
        const { error } = await dbClient
          .from('users')
          .update(payload)
          .eq('id', currentUser.id);

        if (error) throw error;

        // Update session storage
        currentUser = { ...currentUser, ...payload };
        sessionStorage.setItem('school_user', JSON.stringify(currentUser));
        
        // Re-initialize header user displays
        document.getElementById('desktop-user-name').innerText = currentUser.name;
        
        showToast('บันทึกข้อมูลส่วนตัวเรียบร้อยแล้ว', 'success');
      } catch (err) {
        showToast('ไม่สามารถอัปเดตโปรไฟล์ได้', 'danger');
      } finally {
        showLoader(false);
      }
    });

    // ==========================================================
    // LOGOUT LOGIC
    // ==========================================================
    function confirmLogout() {
      document.getElementById('logout-confirm-modal').classList.remove('hidden');
    }

    function hideLogoutConfirm() {
      document.getElementById('logout-confirm-modal').classList.add('hidden');
    }

    function logout() {
      sessionStorage.removeItem('school_user');
      currentUser = null;
      hideLogoutConfirm();
      
      // Toggle view without reload
      document.getElementById('view-app').classList.add('hidden');
      document.getElementById('view-landing').classList.remove('hidden');
      
      // Update landing page counters
      updateLandingStats();
      showToast('ออกจากระบบเรียบร้อยแล้ว', 'info');
    }

    // Helper: generic show view (Guest vs App)
    function showView(viewId) {
      if (viewId === 'view-landing') {
        document.getElementById('view-landing').classList.remove('hidden');
        document.getElementById('view-app').classList.add('hidden');
      } else {
        document.getElementById('view-landing').classList.add('hidden');
        document.getElementById('view-app').classList.remove('hidden');
      }
    }
  </script>
</body>
</html>
